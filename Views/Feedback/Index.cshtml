@model MobileRechargeApp.Models.Feedback
@{
    ViewData["Title"] = "Feedback";
}

<!--========================== Feedback Page Start ==========================-->
<section class="sign__area">

    <div class="sign__bg">
        @* <img src="~/assets/images/banner-bg.png" alt="img"> *@
    </div>

    <div class="container">
        <div class="row g-4 align-items-center">

            <!-- ===== LEFT SIDE ===== -->
                <div class="col-lg-6">
                    <div class="sign__left__blk">

                        <div class="sign__label">
                            <div class="footer__subs__label">
                                <div class="footer__subs__shr">
                                    <img src="~/assets/images/logo/icon-dark.png" alt="img">
                                        <div class="footer__circle__text">
                                            <p>SHARE YOUR EXPERIENCE WITH US</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="sign__title">
                                <span>WE VALUE YOUR</span>
                                <h1>SEND US YOUR <span>Feedback</span></h1>
                            </div>

                            <div class="back__to__home">
                                <a href="/">
                                    <i class="fa-solid fa-arrow-left-long"></i>
                                    Back to Home
                                </a>
                            </div>

                        </div>
                    </div>
                    <!-- ===== LEFT SIDE END ===== -->
            <!-- ===== RIGHT SIDE FORM ===== -->
            <div class="col-lg-6">
                <div class="sign__wrap">

                    @if (ViewBag.Success != null)
                    {
                        <div class="feedback__toast feedback__toast--success" id="successToast">
                            <i class="las la-check-circle"></i>
                            <span>@ViewBag.Success</span>
                            <button class="feedback__toast__close" onclick="this.parentElement.remove()">
                                <i class="las la-times"></i>
                            </button>
                        </div>
                    }

                    <form asp-action="Index" method="post" id="feedbackForm" novalidate>
                        <div class="row g-0">

                            <!-- Name -->
                            <div class="col-lg-12">
                                <div class="sign__wrap__single" id="field-name">
                                    <label asp-for="Name" class="form-label form--label">
                                        Name
                                    </label>
                                    <div class="input--group">
                                        
                                        <input asp-for="Name"
                                               id="Name"
                                               class="form-control form--control"
                                               placeholder="Your full name"
                                               autocomplete="name" />
                                    </div>
                                    <span class="feedback__error" id="err-Name">
                                        <span asp-validation-for="Name"></span>
                                    </span>
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="col-lg-12">
                                <div class="sign__wrap__single" id="field-email">
                                    <label asp-for="Email" class="form-label form--label">
                                        Email
                                    </label>
                                    <div class="input--group">
                                     
                                        <input asp-for="Email"
                                               id="Email"
                                               class="form-control form--control"
                                               placeholder="you@example.com"
                                               autocomplete="email" />
                                    </div>
                                    <span class="feedback__error" id="err-Email">
                                        <span asp-validation-for="Email"></span>
                                    </span>
                                </div>
                            </div>

                           
                            <!-- Message -->
                            <div class="col-lg-12">
                                <div class="sign__wrap__single" id="field-message">
                                    <label asp-for="Message" class="form-label form--label">
                                        Message
                                    </label>
                                    <div class="input--group" style="height:auto; min-height:110px; align-items:flex-start;">
                                   
                                        <textarea asp-for="Message"
                                                  id="Message"
                                                  class="form-control form--control"
                                                  rows="4"
                                                  style="resize:vertical; min-height:110px; padding-top:0.75rem;"
                                                  placeholder="Tell us about your experience..."></textarea>
                                    </div>
                                    <div class="feedback__char-count">
                                        <span id="charCount">0</span> / 500
                                    </div>
                                    <span asp-validation-for="Message" class="feedback__error" id="err-Message"></span>
                                </div>
                            </div>

                            <!-- Buttons -->
                            <div class="col-lg-12">
                                <div class="sign__wrap__single">
                                    <button type="submit" class="common__btn" id="submitBtn">
                                        <span>
                                            Submit Feedback
                                        </span>
                                        <span>
                                            <i class="fa-solid fa-arrow-right"></i>
                                        </span>
                                    </button>
                                    <a asp-controller="Home" asp-action="Index" class="feedback__cancel">
                                        Cancel
                                    </a>
                                </div>
                            </div>

                        </div>
                    </form>

                </div>
            </div>
            <!-- ===== RIGHT SIDE END ===== -->

        </div>
    </div>

</section>
<!--========================== Feedback Page End ==========================-->
<style>
    /* Enhanced Feedback Form Styles */
    .sign__left__blk {
        margin-top: 50px;
        position: relative;
    }

    .sign__label {
        margin-bottom: 30px;
    }

    /* ── Circular spinning badge ── */
    .circular__badge {
        position: relative;
        width: 200px;
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Subtle outer ring */
    .circular__badge__ring {
        position: absolute;
        inset: 10px;
        border-radius: 50%;
        background: linear-gradient(135deg,
            hsl(var(--base) / 0.07) 0%,
            hsl(var(--base-two) / 0.07) 100%);
        border: 1.5px dashed hsl(var(--base) / 0.18);
    }

    /* SVG spins */
    .circular__badge__svg {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        animation: spin__badge 14s linear infinite;
        overflow: visible;
    }

    .circular__badge__svg text {
        font-size: 14.5px;
        font-weight: 600;
        fill: hsl(var(--base));
        letter-spacing: 2px;
        text-transform: uppercase;
        font-family: inherit;
    }

    /* Center icon circle */
    .circular__badge__inner {
        position: relative;
        z-index: 2;
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg,
            hsl(var(--base) / 0.1),
            hsl(var(--base-two) / 0.15));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid hsl(var(--base) / 0.2);
        box-shadow: 0 8px 24px hsl(var(--base) / 0.15);
        backdrop-filter: blur(8px);
    }

    .circular__badge__logo {
        width: 42px;
        height: 42px;
        object-fit: contain;
    }

    @@keyframes spin__badge {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }

    .sign__title {
        margin-bottom: 25px;
    }

    .sign__title span {
        display: block;
        font-size: 1.1rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 10px;
        color: hsl(var(--text-color) / 0.7);
    }

    .sign__title h1 {
        font-size: 3.2rem;
        font-weight: 700;
        line-height: 1.2;
        margin: 0;
    }

    .sign__title h1 span {
        display: inline-block;
        font-size: inherit;
        text-transform: none;
        letter-spacing: normal;
        margin-bottom: 0;
        background: linear-gradient(135deg, hsl(var(--base)), hsl(var(--base-two)));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .feedback__features {
        margin: 30px 0;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .feedback__feature__item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 10px 20px;
        background: hsl(var(--section-bg) / 0.5);
        border-radius: 12px;
        transition: all 0.3s ease;
        backdrop-filter: blur(5px);
        border: 1px solid transparent;
    }

    .feedback__feature__item:hover {
        border-color: hsl(var(--base) / 0.2);
        transform: translateX(10px);
        box-shadow: 0 10px 30px -10px hsl(var(--base) / 0.2);
    }

    .feedback__feature__icon {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        background: linear-gradient(135deg, hsl(var(--base)), hsl(var(--base-two)));
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.2rem;
        flex-shrink: 0;
        box-shadow: 0 10px 20px -5px hsl(var(--base) / 0.3);
    }

    .feedback__feature__item span {
        font-size: 1rem;
        font-weight: 500;
        color: hsl(var(--heading-color));
    }

    .back__to__home {
        margin-top: 40px;
    }

    .back__to__home a {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 25px;
        /* background: hsl(var(--section-bg)); */
        /* border-radius: 30px; */
        color: hsl(var(--heading-color));
        text-decoration: none;
        font-weight: 500;
        transition: all 0.3s ease;
        /* border: 1px solid hsl(var(--border-color) / 0.3); */
    }

    .back__to__home a:hover {
        /* background: hsl(var(--base)); */
        color: #fff;
        transform: translateX(-5px);
        /* border-color: transparent; */
    }

    .back__to__home a i {
        font-size: 0.9rem;
        transition: transform 0.3s ease;
    }

    .back__to__home a:hover i {
        transform: translateX(-5px);
    }

    .sign__wrap {
        width: 530px;
        margin-top: 50px;
        position: relative;
    }

    .sign__wrap::before {
        content: '';
        position: absolute;
        top: -20px;
        right: -20px;
        width: 150px;
        height: 150px;
        background: radial-gradient(circle, hsl(var(--base) / 0.1) 0%, transparent 70%);
        border-radius: 50%;
        z-index: -1;
    }

    .sign__wrap::after {
        content: '';
        position: absolute;
        bottom: -30px;
        left: -30px;
        width: 200px;
        height: 200px;
        background: radial-gradient(circle, hsl(var(--base-two) / 0.08) 0%, transparent 70%);
        border-radius: 50%;
        z-index: -1;
    }

    .sign__wrap__single {
        margin-bottom: 0;
        padding-bottom: 8px;
        position: relative;
        transition: all 0.3s ease;
    }

    .col-lg-12 + .col-lg-12 {
        margin-top: 2px;
    }

    .form--label {
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.9rem;
        font-weight: 600;
        color: hsl(var(--heading-color));
        padding-left: 5px;
    }

    .form--label i {
        color: hsl(var(--base));
        font-size: 1rem;
    }

    .input--group {
        display: flex;
        align-items: center;
        height: 52px;
        border-radius: 16px;
        border: 2px solid hsl(var(--border-color) / 0.2);
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: #ffffff;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
    }

    .input--group:focus-within {
        border-color: hsl(var(--base));
        box-shadow: 0 8px 20px -8px hsl(var(--base) / 0.3);
        transform: translateY(-2px);
    }

    .input--group .input-group-text {
        background: linear-gradient(135deg, hsl(var(--base) / 0.1), hsl(var(--base-two) / 0.1));
        border: none;
        color: hsl(var(--base));
        padding: 0 20px;
        font-size: 1.1rem;
        height: 100%;
        display: flex;
        align-items: center;
    }

    .input--group .form--control {
        border: none;
        height: 100%;
        padding: 0.75rem 0.75rem 0.75rem 10px;
        background: transparent;
        font-size: 0.95rem;
        color: hsl(var(--heading-color));
        font-weight: 500;
    }

    .input--group .form--control:focus {
        box-shadow: none;
        outline: none;
    }

    .input--group .form--control::placeholder {
        color: hsl(var(--text-color) / 0.3);
        font-weight: 400;
    }

    /* Textarea specific styles */
    .input--group.textarea-group {
        height: auto;
        min-height: 120px;
        align-items: flex-start;
    }

    .input--group.textarea-group .input-group-text {
        height: 120px;
        align-items: flex-start;
        padding-top: 15px;
    }

    textarea.form--control {
        padding-top: 15px !important;
        line-height: 1.5;
        resize: vertical;
        min-height: 120px;
    }

    /* Rating Stars Enhanced */
    .feedback__stars {
        display: flex;
        gap: 0.8rem;
        margin-top: 0.5rem;
        justify-content: flex-start;
    }

    .feedback__star {
        background: hsl(var(--section-bg));
        border: 2px solid hsl(var(--border-color) / 0.2);
        border-radius: 12px;
        padding: 0.6rem 1rem;
        cursor: pointer;
        color: hsl(var(--border-color) / 0.5);
        font-size: 1.5rem;
        line-height: 1;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }

    .feedback__star::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: hsl(var(--base) / 0.2);
        transform: translate(-50%, -50%);
        transition: width 0.6s ease, height 0.6s ease;
    }

    .feedback__star:hover::before {
        width: 150px;
        height: 150px;
    }

    .feedback__star:hover,
    .feedback__star.active {
        border-color: hsl(var(--base));
        color: hsl(38 95% 50%);
        transform: translateY(-3px) scale(1.05);
        box-shadow: 0 10px 20px -5px hsl(var(--base) / 0.3);
        background: #fff;
    }

    .feedback__star.active {
        animation: starPulse 0.3s ease;
    }

    @@keyframes starPulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    /* Error State */
    .sign__wrap__single.is-invalid .input--group {
        border-color: hsl(0 90% 55%);
        /* box-shadow: 0 0 0 4px hsl(0 90% 55% / 0.1); */
        animation: shake 0.3s ease;
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-5px); }
        75% { transform: translateX(5px); }
    }

    .feedback__error {
        display: block;
        font-size: 0.75rem;
        color: hsl(0 90% 50%);
        min-height: 1rem;
        margin-top: 0.4rem;
        font-weight: 500;
        padding-left: 5px;
        animation: fadeIn 0.3s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .feedback__char-count {
        text-align: right;
        font-size: 0.75rem;
        color: hsl(var(--text-color) / 0.4);
        margin-top: 0.4rem;
        padding-right: 5px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .feedback__char-count.near-limit { 
        color: hsl(38 95% 45%);
        font-weight: 600;
    }
    
    .feedback__char-count.at-limit { 
        color: hsl(0 90% 50%);
        font-weight: 700;
        animation: pulse 0.5s ease infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
    }

    /* Submit Button Enhanced */
    .sign__wrap .common__btn {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 56px;
        padding: 0 25px;
        border-radius: 16px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        width: 100%;
        border: none;
        cursor: pointer;
        /* background: linear-gradient(135deg, hsl(var(--base)), hsl(var(--base-two))); */
        color: #ffffff;
        text-transform: uppercase;
        letter-spacing: 1px;
        position: relative;
        overflow: hidden;
    }

    .sign__wrap .common__btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        /* background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent); */
        transition: left 0.5s ease;
    }

    .sign__wrap .common__btn:hover::before {
        left: 100%;
    }

    .sign__wrap .common__btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px -8px hsl(var(--base) / 0.4);
    }

    .sign__wrap .common__btn:active {
        transform: translateY(0);
    }

    .sign__wrap .common__btn i {
        transition: transform 0.3s ease;
    }

    .sign__wrap .common__btn:hover i {
        transform: translateX(5px);
    }

    .sign__wrap .common__btn.loading {
        pointer-events: none;
        opacity: 0.9;
    }

    .sign__wrap .common__btn.loading span:first-child {
        opacity: 0;
    }

    .sign__wrap .common__btn.loading::after {
        content: "";
        position: absolute;
        width: 24px;
        height: 24px;
        border: 3px solid #fff;
        border-top-color: transparent;
        border-radius: 50%;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        animation: fbSpin 0.8s linear infinite;
    }

    @@keyframes fbSpin {
        to { transform: translate(-50%, -50%) rotate(360deg); }
    }

    /* Cancel Button Enhanced */
    .feedback__cancel {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 56px;
        padding: 0 25px;
        border-radius: 16px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        width: 100%;
        border: 2px solid hsl(var(--border-color) / 0.3);
        background: transparent;
        color: hsl(var(--text-color));
        text-align: center;
        text-decoration: none;
        margin-top: 15px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .feedback__cancel:hover {
        border-color: hsl(var(--base));
        color: hsl(var(--base));
        background: hsl(var(--base) / 0.04);
        transform: translateY(-3px);
        box-shadow: 0 10px 20px -8px hsl(var(--base) / 0.2);
    }

    /* Toast Notification Enhanced */
    .feedback__toast {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 1rem 1.2rem;
        border-radius: 16px;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        font-weight: 500;
        animation: slideDown 0.4s ease;
        position: relative;
        overflow: hidden;
    }

    .feedback__toast--success {
        background: linear-gradient(135deg, hsl(var(--base) / 0.1), hsl(var(--base-two) / 0.1));
        border: 1px solid hsl(var(--base) / 0.3);
        color: hsl(var(--base));
        backdrop-filter: blur(10px);
    }

    .feedback__toast i {
        font-size: 1.3rem;
    }

    .feedback__toast::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        height: 100%;
        width: 4px;
        background: linear-gradient(135deg, hsl(var(--base)), hsl(var(--base-two)));
    }

    .feedback__toast__close {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: inherit;
        opacity: 0.6;
        font-size: 1.1rem;
        padding: 5px;
        transition: all 0.3s ease;
        border-radius: 8px;
    }

    .feedback__toast__close:hover { 
        opacity: 1;
        background: hsl(var(--base) / 0.1);
        transform: rotate(90deg);
    }

    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Responsive Improvements */
    @@media (max-width: 1200px) {
        .sign__wrap { width: 100%; max-width: 530px; }
        .sign__title h1 { font-size: 2.8rem; }
    }

    @@media (max-width: 991px) {
        .sign__left__blk { margin-top: 0; text-align: center; }
        .footer__subs__shr { margin: 0 auto; }
        .feedback__features { align-items: center; }
        .feedback__feature__item { justify-content: flex-start; width: 100%; max-width: 400px; margin: 0 auto; }
        .feedback__feature__item:hover { transform: translateX(0) translateY(-5px); }
        .sign__wrap { margin: 40px auto 0; }
        .back__to__home { display: flex; justify-content: center; }
    }

    @@media (max-width: 768px) {
        .sign__title h1 { font-size: 2.4rem; }
        .feedback__stars { flex-wrap: wrap; justify-content: center; }
        .feedback__star { flex: 0 0 auto; }
    }

    @@media (max-width: 576px) {
        .sign__title h1 { font-size: 2rem; }
        .feedback__stars { gap: 0.5rem; }
        .feedback__star { padding: 0.5rem 0.8rem; font-size: 1.3rem; }
        .sign__wrap { padding: 0 15px; }
        .input--group { height: 48px; }
        .sign__wrap .common__btn,
        .feedback__cancel { height: 50px; }
    }

    /* Smooth Scrolling for error focus */
    html {
        scroll-behavior: smooth;
    }

</style>
<script>
(function () {

    function setValid(fieldEl) {
        fieldEl.classList.remove('is-invalid');
    }
    function setInvalid(fieldEl, msg) {
        fieldEl.classList.add('is-invalid');
        const err = fieldEl.querySelector('.feedback__error');
        if (err) err.textContent = msg;
    }
    function clearState(fieldEl) {
        fieldEl.classList.remove('is-invalid');
        const err = fieldEl.querySelector('.feedback__error');
        if (err) err.textContent = '';
    }

    const nameEl    = document.getElementById('Name');
    const emailEl   = document.getElementById('Email');
    const msgEl     = document.getElementById('Message');
    const ratingEl  = document.getElementById('Rating');
    const form      = document.getElementById('feedbackForm');
    const submitBtn = document.getElementById('submitBtn');

    const fieldName   = document.getElementById('field-name');
    const fieldEmail  = document.getElementById('field-email');
    const fieldMsg    = document.getElementById('field-message');
    const fieldRating = document.getElementById('field-rating');
    const ratingErrEl = document.getElementById('err-Rating');

    function validateName() {
        const v = (nameEl.value || '').trim();
        if (!v)            { setInvalid(fieldName, 'Name is required.'); return false; }
        if (v.length < 2)  { setInvalid(fieldName, 'Name must be at least 2 characters.'); return false; }
        if (v.length > 100){ setInvalid(fieldName, 'Name must be under 100 characters.'); return false; }
        var nameRx = new RegExp('^[A-Za-z \\-\\.\' ]+$');
        if (!nameRx.test(v)) { setInvalid(fieldName, 'Name contains invalid characters.'); return false; }
        setValid(fieldName); return true;
    }

    function validateEmail() {
        const v = (emailEl.value || '').trim();
        if (!v) { setInvalid(fieldEmail, 'Email address is required.'); return false; }
        var atSign = String.fromCharCode(64);
        var atIdx  = v.indexOf(atSign);
        var dotIdx = v.lastIndexOf('.');
        var spIdx  = v.indexOf(' ');
        var emailOk = atIdx > 0 && dotIdx > atIdx + 1 && dotIdx < v.length - 2 && spIdx === -1;
        if (!emailOk) { setInvalid(fieldEmail, 'Please enter a valid email address.'); return false; }
        setValid(fieldEmail); return true;
    }

    function validateRating() {
        if (parseInt(ratingEl.value || '0') === 0) {
            fieldRating.classList.add('is-invalid');
            ratingErrEl.style.display = 'block';
            return false;
        }
        fieldRating.classList.remove('is-invalid');
        ratingErrEl.style.display = 'none';
        return true;
    }

    function validateMessage() {
        const v = (msgEl.value || '').trim();
        if (!v)            { setInvalid(fieldMsg, 'Please write a message before submitting.'); return false; }
        if (v.length < 10) { setInvalid(fieldMsg, 'Message must be at least 10 characters.'); return false; }
        if (v.length > 500){ setInvalid(fieldMsg, 'Message must be under 500 characters.'); return false; }
        setValid(fieldMsg); return true;
    }

    nameEl.addEventListener('blur',  validateName);
    emailEl.addEventListener('blur', validateEmail);
    msgEl.addEventListener('blur',   validateMessage);

    nameEl.addEventListener('focus',  () => clearState(fieldName));
    emailEl.addEventListener('focus', () => clearState(fieldEmail));
    msgEl.addEventListener('focus',   () => clearState(fieldMsg));

    const charCount = document.getElementById('charCount');
    const charWrap  = document.querySelector('.feedback__char-count');
    msgEl.addEventListener('input', function () {
        const len = this.value.length;
        charCount.textContent = len;
        charWrap.classList.toggle('near-limit', len >= 400 && len < 500);
        charWrap.classList.toggle('at-limit',   len >= 500);
    });

    const stars = Array.from(document.querySelectorAll('.feedback__star'));
    let ratingVal = 0;

    function paintStars(upTo) {
        stars.forEach((s, i) => s.classList.toggle('active', i < upTo));
    }

    stars.forEach((star, idx) => {
        star.addEventListener('mouseenter', () => paintStars(idx + 1));
        star.addEventListener('mouseleave', () => paintStars(ratingVal));
        star.addEventListener('click', () => {
            ratingVal = idx + 1;
            ratingEl.value = ratingVal;
            paintStars(ratingVal);
            fieldRating.classList.remove('is-invalid');
            ratingErrEl.style.display = 'none';
        });
        star.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                ratingVal = idx + 1;
                ratingEl.value = ratingVal;
                paintStars(ratingVal);
            }
        });
    });

    form.addEventListener('submit', function (e) {
        const n  = validateName();
        const em = validateEmail();
        const r  = validateRating();
        const m  = validateMessage();
        if (!n || !em || !r || !m) {
            e.preventDefault();
            const firstErr = form.querySelector('.is-invalid');
            if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
        }
        submitBtn.classList.add('loading');
        submitBtn.disabled = true;
    });

    const existingRating = parseInt(ratingEl.value || '0');
    if (existingRating > 0) { ratingVal = existingRating; paintStars(ratingVal); }

    const toast = document.getElementById('successToast');
    if (toast) {
        setTimeout(() => {
            toast.style.transition = 'opacity .4s';
            toast.style.opacity = '0';
            setTimeout(() => toast.remove(), 400);
        }, 4000);
    }

})();
</script>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}