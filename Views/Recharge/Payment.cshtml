@model MobileRechargeApp.Models.PaymentViewModel
@{
    ViewData["Title"] = "Payment";
}

<section class="sign__area">
    <div class="sign__bg">
        @* <img src="~/assets/images/banner-bg.png" alt="img"> *@
    </div>
    @* <div class="sign__sp1"><img src="~/assets/images/wave-sp.png" alt="img"></div> *@
    @* <div class="sign__sp2"><img src="~/assets/images/wave-sp.png" alt="img"></div> *@

    <div class="container">
        <div class="sign__wrap">

            <!-- Header -->
            <div class="text-center mb-5">
                
                <h3 class="mt-3">Secure Payment</h3>
                <p class="text-dark">Review your recharge details below</p>
            </div>

            <div class="row g-4 align-items-stretch">

                <!-- LEFT SIDE -->
                <div class="col-lg-5">
                    <div class="payment-summary">

                        <div class="mobile-summary-header d-flex align-items-center gap-3 mb-4">
                            <div class="mobile-icon">
                                <i class="las la-mobile"></i>
                            </div>
                            <div>
                                <small>Mobile Number</small>
                                <h5>@Model.MobileNumber</h5>
                            </div>
                        </div>

                        <div class="summary-divider"></div>

                        <div class="summary-row">
                            <span>Plan Details</span>
                            <strong>@Model.Description</strong>
                        </div>

                        <div class="summary-row">
                            <span>Plan Type</span>
                            <span class="badge-custom">
                                @(Model.PlanType == "topup" ? "Top Up" : "Special Plan")
                            </span>
                        </div>

                        <div class="summary-total">
                            Total Amount:
                            <strong>Rs. @Model.Amount</strong>
                        </div>

                    </div>
                </div>

                <!-- RIGHT SIDE -->
                <div class="col-lg-7">

                    <!-- FORM -->
                    <form asp-action="Payment"
                          method="post"
                          class="payment-form"
                          id="paymentForm">

                        <input type="hidden" asp-for="MobileNumber" />
                        <input type="hidden" asp-for="PlanId" />
                        <input type="hidden" asp-for="PlanType" />
                        <input type="hidden" asp-for="Amount" />
                        <input type="hidden" asp-for="Description" />

                        <label class="form-label fw-bold mb-4">
                            <i class="las la-credit-card me-2"></i>
                            Select Payment Method
                        </label>

                        <div class="row g-4">

                            <div class="col-md-6">
                                <label class="payment-option">
                                    <input type="radio" asp-for="PaymentMethod" value="Credit Card" />
                                    <div class="payment-option-content">
                                        <i class="las la-credit-card text-dark"></i>
                                        <span>Credit Card</span>
                                    </div>
                                </label>
                            </div>

                            <div class="col-md-6">
                                <label class="payment-option">
                                    <input type="radio" asp-for="PaymentMethod" value="Debit Card" />
                                    <div class="payment-option-content">
                                        <i class="las la-credit-card text-dark"></i>
                                        <span>Debit Card</span>
                                    </div>
                                </label>
                            </div>

                            

                            <div class="col-md-6">
                                <label class="payment-option">
                                    <input type="radio" asp-for="PaymentMethod" value="Easypaisa" />
                                    <div class="payment-option-content">
                                        <i class="las la-mobile text-dark"></i>
                                        <span>Easypaisa</span>
                                    </div>
                                </label>
                            </div>

                            <div class="col-md-6">
                                <label class="payment-option">
                                    <input type="radio" asp-for="PaymentMethod" value="JazzCash" />
                                    <div class="payment-option-content">
                                        <i class="las la-mobile text-dark"></i>
                                        <span>JazzCash</span>
                                    </div>
                                </label>
                            </div>

                        </div>

                        <span asp-validation-for="PaymentMethod" class="text-danger small"></span>

                    </form>

                </div>
            </div>

            <!-- ✅ PAY BUTTON (FORM KE BAHAR) -->
            <div class="d-grid mt-5">
                <button type="submit"
                        form="paymentForm"
                        class="common__btn pay-btn w-100">
                    <span style="width:100%;">Pay Rs. @Model.Amount</span>
                    <span><i class="fa-solid fa-lock"></i></span>
                </button>
            </div>

            <!-- Security Note -->
            <div class="alert secure-note mt-4 mb-0">
                <small>
                    <i class="las la-shield-alt"></i>
                    Your payment is secure and encrypted. We never store your payment details.
                </small>
            </div>

        </div>
    </div>
</section>

<style>
    /* Page Feel Upgrade */
    body {
        background: linear-gradient(135deg, #f6f9ff, #f1f5ff);
    }

    /* Main Wrapper */
    .sign__wrap {
        max-width: 1000px;
        margin: 80px auto;
        padding: 60px;
        border-radius: 35px;
        background: rgba(255,255,255,0.75);
        backdrop-filter: blur(12px);
        box-shadow: 0 30px 70px rgba(0,0,0,0.08);
        border: 1px solid rgba(255,255,255,0.6);
    }

        /* Header */
        .sign__wrap h3 {
            font-weight: 700;
            font-size: 1.8rem;
        }

        .sign__wrap p {
            font-size: 0.95rem;
            opacity: 0.8;
        }


    /* Card Base */
    .payment-summary,
    .payment-form {
        background: white;
        border-radius: 28px;
        padding: 40px;
        border: 1px solid #f0f0f0;
        height: 100%;
        transition: all 0.35s ease;
    }

        /* .payment-summary:hover,
        .payment-form:hover {
            transform: translateY(-6px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.08);
        } */

    /* Mobile Header */
    .mobile-summary-header {
        padding: 20px;
        background: #f9fbff;
        border-radius: 18px;
    }

    .mobile-icon {
        width: 65px;
        height: 65px;
        border-radius: 18px;
        background: hsl(var(--base) / 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: hsl(var(--base));
        font-size: 1.8rem;
    }

    /* Divider */
    .summary-divider {
        height: 1px;
        background: #eee;
        margin: 30px 0;
    }

    /* Summary Rows */
    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 18px;
        font-size: 0.95rem;
        color: #666;
    }

        .summary-row strong {
            color: #222;
        }

    /* Total Highlight */
    .summary-total {
        margin-top: 20px;
        padding: 25px;
        border-radius: 18px;
        background: linear-gradient(135deg, hsl(var(--base) / 0.08), transparent);
        text-align: right;
        font-size: 1.2rem;
    }

        .summary-total strong {
            font-size: 1.8rem;
            /* color: black; */
            color: hsl(var(--base));
        }

    /* Payment Options */
    .payment-option {
        display: block;
        cursor: pointer;
    }

        .payment-option input {
            display: none;
        }

    .payment-option-content {
        border: 1px solid #eee;
        border-radius: 22px;
        padding: 30px 20px;
        text-align: center;
        transition: all 0.3s ease;
        background: #fafcff;
        height: 100%;
    }

        .payment-option-content i {
            font-size: 2.4rem;
            margin-bottom: 14px;
            color: hsl(var(--base));
            transition: 0.3s;
        }

        .payment-option-content span {
            font-weight: 600;
        }

    /* Hover */
    /* Remove old hover shadow */
    .payment-option:hover .payment-option-content {
        transform: translateY(-6px);
        box-shadow: none;
        border: 2px solid #1DA5A5;
    }

    /* Selected (Checked) */
    .payment-option input:checked + .payment-option-content {
        border: 2px solid #1DA5A5;
        background: white;
        box-shadow: none;
    }

    /* Focus (keyboard accessibility) */
    .payment-option input:focus + .payment-option-content {
        border: 2px solid #1DA5A5;
        box-shadow: none;
    }

    /* Selected */
    .payment-option input:checked + .payment-option-content {
        border: 2px solid hsl(var(--base));
        background: white;
        box-shadow: 0 15px 35px hsl(var(--base) / 0.2);
    }

        .payment-option input:checked + .payment-option-content i {
            transform: scale(1.15);
        }

    /* Premium Pay Button */
    .pay-btn {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 14px;
        height: 65px;
        border-radius: 22px;
        font-weight: 700;
        font-size: 1.1rem;
        /* background: linear-gradient(135deg, hsl(var(--base)), hsl(var(--base) / 0.8)); */
        color: white;
        border: none;
        transition: all 0.3s ease;
    }


    /* Security Note */
    .secure-note {
        background: hsl(var(--base) / 0.06);
        border-left: 5px solid hsl(var(--base));
        border-radius: 16px;
        padding: 14px 18px;
    }

        .secure-note small {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.9rem;
        }

    /* Responsive Improvements */
    @@media (max-width: 992px) {

        .sign__wrap {
            padding: 35px;
        }

        .payment-summary,
        .payment-form {
            padding: 28px;
        }

        .summary-total {
            font-size: 1.2rem;
        }
    }

    @@media (max-width: 576px) {

        .sign__wrap {
            padding: 25px;
            border-radius: 20px;
        }

        .payment-option-content {
            padding: 22px 15px;
        }

        .pay-btn {
            height: 55px;
            font-size: 1rem;
        }
    }</style>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}