@model IEnumerable<MobileRechargeApp.Models.TopUpPlan>
@{
    ViewData["Title"] = "Top Up Plans";
}

<section class="sign__area">

    @* ✅ Same background as Recharge Index *@
    <div class="sign__bg">
        @* <img src="~/assets/images/banner-bg.png" alt="img"> *@
    </div>
    @* <div class="sign__sp1"><img src="~/assets/images/wave-sp.png" alt="img"></div> *@
    @* <div class="sign__sp2"><img src="~/assets/images/wave-sp.png" alt="img"></div> *@

    <div class="container">
        <div class="row g-4 align-items-start">

            <!-- LEFT SIDE -->
            <div class="col-lg-5">
                <div class="sign__left__blk mt-3">

                    <div class="sign__label">
                        <div class="footer__subs__label">
                            <div class="footer__subs__shr">
                                <img src="~/assets/images/logo/icon-dark.png" alt="img">
                                <div class="footer__circle__text">
                                    <p>Choose the best plan for your needs.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="sign__title">
                        <span>Choose Your Plan</span>
                        <h1>Top Up <span>Plans</span></h1>
                        <p class="mt-3 text-dark">
                            Mobile Number: <strong>@ViewBag.Mobile</strong>
                        </p>
                    </div>

                    <div class="back__to__home">
                        <a asp-controller="Recharge" asp-action="Index">
                            <i class="fa-solid fa-arrow-left-long"></i>
                            Change Number
                        </a>
                    </div>

                </div>
            </div>
            <!-- LEFT SIDE END -->

            <!-- RIGHT SIDE TABLE -->
            <div class="col-lg-7">
                <div class="sign__wrap mt-4">

                    <form asp-action="Payment" method="get">
                        <input type="hidden" name="mobile" value="@ViewBag.Mobile" />
                        <input type="hidden" name="planType" value="topup" />

                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr style="border-bottom:2px solid #eee;">
                                        <th>Select</th>
                                        <th>Amount</th>
                                        <th>Talk Time</th>
                                        <th>Validity</th>
                                        <th>Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var plan in Model)
                                    {
                                        <tr class="plan-row">
                                            <td>
                                                <input type="radio"
                                                       name="planId"
                                                       value="@plan.PlanId"
                                                       required />
                                            </td>
                                            <td><strong>Rs. @plan.Amount</strong></td>
                                            <td>Rs. @plan.TalkTime</td>
                                            <td>@plan.Validity Day(s)</td>
                                            <td>@plan.Description</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="common__btn w-100">
                                <span style="width:100%;">Proceed to Payment</span>
                                <span><i class="fa-solid fa-arrow-right"></i></span>
                            </button>
                        </div>
                    </form>

                </div>
            </div>
            <!-- RIGHT SIDE END -->

        </div>
    </div>

</section>

<style>
    /* Button container spacing */
    .d-flex.gap-3 {
        margin-top: 20px !important;
    }

        /* Fix both buttons layout */
        .d-flex .common__btn {
    /* display: flex; */
    justify-content: space-between;
    align-items: center;
    height: 52px;
    padding: 0 30px;
    border-radius: 10px;
    width: 100%;        /* ADD THIS */
    min-width: unset;   /* REMOVE MIN-WIDTH */
}
            /* Proper arrow alignment */
            .d-flex.gap-3 .common__btn span:last-child {
                display: flex;
                align-items: center;
            }

            

            /* Smooth hover */
            .d-flex.gap-3 .common__btn:hover {
                transform: translateY(-2px);
            }

    .plan-row {
        transition: all 0.3s ease;
        border-bottom: 1px solid #f1f1f1;
    }

    .plan-row:hover {
        /* background-color: #f0fff8; */
        transform: translateY(-2px);
    }

    .plan-row input[type="radio"]:checked {
        accent-color: #1DA5A5;
    }

    .table th {
        font-weight: 600;
        color: #333;
    }

    .table td {
        vertical-align: middle;
    }
</style>
