@model IEnumerable<MobileRechargeApp.Models.TopUpPlan>
@{
    ViewData["Title"] = "Top Up Plans";
    Layout = "_Layout";
}

@section Styles {
<style>
    .plans-page {
        min-height: 100vh;
        background: white;
        /* background: #0a0f0f; */
        padding: 100px 0 60px;
        position: relative;
        overflow: hidden;
    }
    .plans-page::before {
        content: '';
        position: absolute;
        top: -200px; right: -100px;
        width: 500px; height: 500px;
        /* background: radial-gradient(circle, hsl(180 70% 38% / 0.1) 0%, transparent 70%); */
        pointer-events: none;
    }

    .plans-header {
        text-align: center;
        margin-bottom: 40px;
    }
    .plans-header h6 {
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: hsl(180 70% 45%);
        margin-bottom: 10px;
    }
    .plans-header h1 {
        font-size: 36px;
        font-weight: 800;
                color: #14537A;
        font-family: 'ClashDisplay-Variable', sans-serif;
        margin-bottom: 10px;
    }
    .plans-header h1 span { color: hsl(180 70% 48%); }
    .plans-header p { color: #4a7070; font-size: 14px; }
    .mobile-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: hsl(180 70% 38% / 0.1);
        border: 1px solid hsl(180 70% 38% / 0.3);
        border-radius: 30px;
        padding: 6px 16px;
        font-size: 13px;
        color: hsl(180 70% 55%);
        margin-bottom: 30px;
        font-family: 'Menlo', monospace;
    }
    .mobile-badge i { font-size: 15px; }

    /* Plan cards grid */
    .plans-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }
    .plan-card {
        /* background: #0e1818; */
        border: 1.5px solid #1a2e2e;
        border-radius: 18px;
        padding: 24px;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(.4,0,.2,1);
        position: relative;
        overflow: hidden;
    }
    .plan-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
         background: linear-gradient(90deg, hsl(180 70% 38%), hsl(200 85% 48%)); 
        opacity: 0;
        transition: opacity 0.25s;
    }
    .plan-card:hover {
         border-color: hsl(180 70% 38% / 0.4);
        transform: translateY(-4px);
        /* box-shadow: 0 20px 50px rgba(0,0,0,0.4), 0 0 0 1px hsl(180 70% 38% / 0.1); */
    }
    .plan-card:hover::before { opacity: 1; }

    .plan-price {
        margin-bottom: 16px;
    }
    .plan-price .currency { font-size: 14px; color: hsl(180 70% 45%); font-weight: 700; vertical-align: top; line-height: 2; }
    .plan-price .amount {
        font-size: 42px;
        font-weight: 900;
                color: #14537A;
        font-family: 'ClashDisplay-Variable', sans-serif;
        line-height: 1;
    }
    .plan-name {
        font-size: 15px;
        font-weight: 800;
        color: #c0d8d8;
        margin-bottom: 14px;
        padding-bottom: 14px;
        border-bottom: 1px solid #1a2e2e;
    }
    .plan-features { list-style: none; padding: 0; margin: 0 0 20px; }
    .plan-features li {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        color: #5a8080;
        padding: 5px 0;
    }
    .plan-features li i {
        color: hsl(180 70% 48%);
        font-size: 15px;
        flex-shrink: 0;
    }
    .plan-features li span { color: #a0c0c0; }

    .plan-validity {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: hsl(180 70% 38% / 0.1);
        border: 1px solid hsl(180 70% 38% / 0.2);
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
        color: hsl(180 70% 55%);
        margin-bottom: 18px;
    }

    .btn-select-plan {
        width: 100%;
        padding: 12px;
            background: #1da5a5;
        /* background: linear-gradient(135deg, hsl(180 70% 38%), hsl(200 85% 48%));  */
        border: none;
        border-radius: 10px;
        color: #fff;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
    }
    .btn-select-plan:hover {
        box-shadow: 0 8px 25px hsl(180 70% 38% / 0.4);
        transform: translateY(-1px);
        color: #fff;
    }

    /* Back link */
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #4a7070;
        font-size: 13px;
        text-decoration: none;
        transition: color 0.2s;
        margin-bottom: 30px;
    }
    .back-link:hover { color: hsl(180 70% 55%); }
</style>
}

<div class="plans-page">
    <div class="container">

        @await Html.PartialAsync("_PaymentStepper", "plan")

        <div class="plans-header">
            <h6>Step 1 of 3</h6>
            <h1>Choose Your <span>Top-Up Plan</span></h1>
            <p>Select a plan to recharge for</p>
            <div class="mobile-badge">
                <i class="las la-mobile-alt"></i>
                @ViewBag.Mobile
            </div>
        </div>

        <a href="/Recharge" class="back-link">
            <i class="las la-arrow-left"></i> Change Number
        </a>

        <div class="plans-grid">
            @foreach (var plan in Model)
            {
                <div class="plan-card">
                    <div class="plan-price">
                        <span class="currency">Rs.</span>
                        <span class="amount">@plan.Amount</span>
                    </div>
                    <div class="plan-validity">
                        <i class="las la-calendar-alt"></i> @plan.Validity Days
                    </div>
                    <ul class="plan-features">
                        <li><i class="las la-phone"></i> <span>Rs. @plan.TalkTime</span> Talk Time</li>
                        @if (!string.IsNullOrEmpty(plan.Description))
                        {
                            <li><i class="las la-info-circle"></i> @plan.Description</li>
                        }
                    </ul>
                    <a href="/Recharge/Payment?mobile=@ViewBag.Mobile&planId=@plan.PlanId&planType=topup"
                       class="btn-select-plan">
                        <i class="las la-bolt"></i>
                        Select Plan
                    </a>
                </div>
            }
        </div>

    </div>
</div>
