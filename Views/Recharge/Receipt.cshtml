@model MobileRechargeApp.Models.Transaction
@{
    ViewData["Title"] = "Payment Receipt";
    Layout = "_Layout";
}

@section Styles {
<style>
    .receipt-page {
        min-height: 100vh;
        /* background: #0a0f0f; */
        padding: 100px 0 60px;
        position: relative;
        overflow: hidden;
    }
    .receipt-page::before {
        content: '';
        position: absolute;
        top: -150px; left: 50%;
        transform: translateX(-50%);
        width: 600px; height: 400px;
        /* background: radial-gradient(ellipse, hsl(180 70% 38% / 0.1) 0%, transparent 70%); */
        pointer-events: none;
    }

    .receipt-wrap {
        max-width: 520px;
        margin: 0 auto;
    }

    /* Success animation */
    .success-icon {
        text-align: center;
        margin-bottom: 28px;
    }
    .success-ring {
        width: 80px; height: 80px;
        border-radius: 50%;
        background: hsl(180 70% 38% / 0.12);
        border: 2px solid hsl(180 70% 38% / 0.4);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        animation: popIn 0.5s cubic-bezier(.4,0,.2,1) forwards;
        box-shadow: 0 0 40px hsl(180 70% 38% / 0.25);
    }
    @@keyframes popIn {
        from { transform: scale(0.5); opacity: 0; }
        to   { transform: scale(1);   opacity: 1; }
    }
    .success-title {
        text-align: center;
        font-size: 26px;
        font-weight: 800;
            color: #14537A;
        font-family: 'ClashDisplay-Variable', sans-serif;
        margin-bottom: 6px;
    }
    .success-sub {
        text-align: center;
        font-size: 13px;
        color: #4a7070;
        margin-bottom: 32px;
    }

    /* Receipt card */
    .receipt-card {
        /* background: #0e1818; */
            border: 1px solid #14537A;
        border-radius: 20px;
        overflow: hidden;
        /* box-shadow: 0 30px 80px rgba(0,0,0,0.5); */
    }

    /* Card top stripe */
    .receipt-stripe {
        height: 4px;
        background: linear-gradient(90deg, hsl(180 70% 38%), hsl(200 85% 48%), hsl(180 70% 38%));
        background-size: 200% 100%;
        animation: shimmer 2s linear infinite;
    }
    @@keyframes shimmer {
        from { background-position: 200% 0; }
        to   { background-position: -200% 0; }
    }

    /* TXN header */
    .receipt-header {
        padding: 24px 28px 20px;
        border-bottom: 1px solid #1a2e2e;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }
    .txn-id {
        font-family: 'Menlo', monospace;
        font-size: 13px;
        font-weight: 700;
        color: hsl(180 70% 55%);
    }
    .txn-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: hsl(180 70% 38% / 0.12);
        border: 1px solid hsl(180 70% 38% / 0.3);
        border-radius: 20px;
        padding: 4px 14px;
        font-size: 12px;
        font-weight: 700;
        color: hsl(180 70% 55%);
    }

    /* Amount highlight */
    .receipt-amount {
        padding: 24px 28px;
        border-bottom: 1px solid #1a2e2e;
        text-align: center;
    }
    .receipt-amount .label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #3a5555;
        margin-bottom: 8px;
    }
    .receipt-amount .value {
        font-size: 48px;
        font-weight: 900;
                color: #14537A;
        font-family: 'ClashDisplay-Variable', sans-serif;
        line-height: 1;
    }
    .receipt-amount .value span { font-size: 22px; color: hsl(180 70% 48%); font-weight: 700; vertical-align: top; line-height: 2.2; }

    /* Detail rows */
    .receipt-rows { padding: 8px 28px; }
    .receipt-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 0;
        border-bottom: 1px solid #0e1c1c;
    }
    .receipt-row:last-child { border-bottom: none; }
    .rr-label {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 12px;
        color: #3a5a5a;
    }
    .rr-label i { font-size: 16px; color: #2a4848; }
    .rr-value {
        font-size: 13px;
        font-weight: 700;
        color: #c0d8d8;
        font-family: 'Menlo', monospace;
        text-align: right;
    }

    /* Divider with scissors */
    .receipt-tear {
        border: none;
        border-top: 2px dashed #1a2e2e;
        margin: 0 28px;
        position: relative;
    }
    .receipt-tear::before {
        content: '✂';
        position: absolute;
        left: -12px; top: -10px;
        font-size: 14px;
        color: #1a2e2e;
        background: #0e1818;
        padding: 0 4px;
    }

    /* Action buttons */
    .receipt-actions {
        padding: 24px 28px;
        display: flex;
        gap: 12px;
    }
    .btn-print {
        flex: 1; padding: 13px;
        background: hsl(180 70% 38% / 0.1);
        border: 1.5px solid hsl(180 70% 38% / 0.3);
        border-radius: 12px;
        color: hsl(180 70% 55%);
        font-size: 13px; font-weight: 700;
        cursor: pointer; transition: all 0.2s;
        display: flex; align-items: center; justify-content: center; gap: 8px;
    }
    .btn-print:hover {
        background: hsl(180 70% 38% / 0.2);
        border-color: hsl(180 70% 38%);
    }
    .btn-home {
        flex: 1; padding: 13px;
            background: #1da5a5;
            border: none; border-radius: 12px;
        color: #fff; font-size: 13px; font-weight: 700;
        cursor: pointer; transition: all 0.2s;
        display: flex; align-items: center; justify-content: center; gap: 8px;
        text-decoration: none;
    }
    .btn-home:hover {
        box-shadow: 0 8px 25px hsl(180 70% 38% / 0.4);
        transform: translateY(-1px); color: #fff;
    }

    @@media print {
        .receipt-page { background: #fff; padding: 20px 0; }
        .receipt-actions { display: none; }
        .receipt-card { box-shadow: none; border: 1px solid #ddd; }
        .checkout-stepper { display: none; }
        .success-ring { border-color: #00a651; }
        .receipt-stripe { background: #00a651; animation: none; }
        .receipt-amount .value { color: #000; }
        .receipt-amount .value span, .txn-id, .txn-status { color: #00a651; }
        .rr-value { color: #000; }
        .rr-label { color: #666; }
        .receipt-card { background: #fff; }
        .receipt-page::before { display: none; }
    }
</style>
}

<div class="receipt-page">
    <div class="container">
        <div class="receipt-wrap">

            @await Html.PartialAsync("_PaymentStepper", "receipt")

            <div class="success-icon">
                <div class="success-ring">✓</div>
            </div>
            <div class="success-title">Payment Successful!</div>
            <div class="success-sub">Your recharge has been processed. Save your receipt below.</div>

            <div class="receipt-card">
                <div class="receipt-stripe"></div>

                <div class="receipt-header">
                    <div class="txn-id">#TXN@(Model.TxnId.ToString("D6"))</div>
                    <div class="txn-status">
                        <i class="las la-check-circle"></i>
                        @Model.Status
                    </div>
                </div>

                <div class="receipt-amount">
                    <div class="label">Amount Paid</div>
                    <div class="value"><span>Rs. </span>@Model.Amount</div>
                </div>

                <div class="receipt-rows">
                    <div class="receipt-row">
                        <div class="rr-label"><i class="las la-mobile-alt"></i> Mobile Number</div>
                        <div class="rr-value">@Model.MobileNumber</div>
                    </div>
                    <div class="receipt-row">
                        <div class="rr-label"><i class="las la-box"></i> Plan Type</div>
                        <div class="rr-value">
                            @(Model.PlanType == "topup" ? "Top-Up Plan" :
                              Model.PlanType == "special" ? "Special Plan" : "Postpaid Bill")
                        </div>
                    </div>
                    <div class="receipt-row">
                        <div class="rr-label"><i class="las la-credit-card"></i> Payment Method</div>
                        <div class="rr-value">@Model.PaymentMethod</div>
                    </div>
                    <div class="receipt-row">
                        <div class="rr-label"><i class="las la-calendar"></i> Date & Time</div>
                        <div class="rr-value">@Model.TxnDate.ToString("dd MMM yyyy  HH:mm")</div>
                    </div>
                </div>

                <hr class="receipt-tear" />

                <div class="receipt-actions">
                    <button class="btn-print" onclick="window.print()">
                        <i class="las la-print"></i> Print
                    </button>
                    <a href="/" class="btn-home">
                        <i class="las la-home"></i> Go Home
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
