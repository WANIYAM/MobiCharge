@{
    ViewData["Title"] = "Privacy Policy";
}

<!--========================== Banner Section Start ==========================-->
<section class="banner__area">
    @* <div class="banner__bg"><img src="~/assets/images/banner-bg.png" alt="img"></div> *@
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="banner__topbar">
                    <div class="banner__title">
                        <h2>Our <span>Privacy Policy</span></h2>
                    </div>
                    <div class="banner__btn">
                        <a href="/" class="common__btn"><span>Back to Home</span><span><i class="fa-solid fa-arrow-right"></i></span></a>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <div class="banner__thumb">
                    <video autoplay muted loop>
                        <source src="~/assets/images/banner-thumb.mp4" type="video/mp4">
                    </video>
                </div>
            </div>
        </div>
    </div>
</section>
<!--========================== Banner Section End ==========================-->

<!--========================== Privacy Intro Section Start ==========================-->
<section class="about__details">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="about__details__wrap">
                    <div class="about__details__label">
                        <div class="footer__subs__label about-label">
                            <div class="footer__subs__shr">
                                <img src="~/assets/images/about/label-sp.png" alt="img">
                                <div class="footer__circle__text">
                                    <p>Your data is safe &amp; protected with us.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="about__details__content">
                        <h5>
                            At MobiCharge, your privacy is our priority. This policy explains what information
                            we collect, how we use it, and the steps we take to keep it secure. By using our
                            platform, you agree to the practices described below.
                        </h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!--========================== Privacy Intro Section End ==========================-->

<!--========================== Privacy Policy Details Section Start ==========================-->
<section class="about__feature" style="padding: 80px 0;">
    @* <div class="about__fsp"><img src="~/assets/images/yellow-sp.png" alt="img"></div> *@
    <div class="about__fsp2"><img src="~/assets/images/circle-sp.png" alt="img"></div>
    <div class="about__fsp3"><img src="~/assets/images/wave-sp.png" alt="img"></div>

    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="feature__title">
                    <h2 data-aos="fade-up-left" data-aos-delay="200" data-aos-duration="1200">
                        What We <span>Collect & How</span>
                    </h2>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <div class="about__feature__wrap">

                    <!-- Data We Collect -->
                    <div class="about__feature__wrap__single">
                        <div class="about__feature__wrap__single__title">
                            <h4>Data We <br>Collect</h4>
                        </div>
                        <div class="about__feature__wrap__single__content">
                            <p>
                                We collect only the information necessary to provide you with a smooth
                                recharge and payment experience. No sensitive financial data is stored on our servers.
                            </p>
                            <ul>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Mobile number &amp; email address</li>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Transaction IDs &amp; recharge history</li>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Device &amp; browser information</li>
                            </ul>
                        </div>
                    </div>

                    <!-- How We Use It -->
                    <div class="about__feature__wrap__single">
                        <div class="about__feature__wrap__single__title">
                            <h4>How We <br>Use It</h4>
                        </div>
                        <div class="about__feature__wrap__single__content">
                            <p>
                                Your information is used exclusively to process transactions, manage your account,
                                and improve our services. We do not sell or share your data with third parties
                                for marketing purposes.
                            </p>
                            <ul>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Process recharge &amp; bill payments</li>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Send transaction receipts</li>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Improve platform performance</li>
                            </ul>
                        </div>
                    </div>

                    <!-- How We Protect It -->
                    <div class="about__feature__wrap__single">
                        <div class="about__feature__wrap__single__title">
                            <h4>How We <br>Protect It</h4>
                        </div>
                        <div class="about__feature__wrap__single__content">
                            <p>
                                All data is transmitted over encrypted HTTPS connections. Payment processing
                                is handled through trusted and certified payment gateways. Access to user
                                data is strictly restricted.
                            </p>
                            <ul>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>HTTPS encryption on all pages</li>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Secure certified payment gateways</li>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Role-based access control</li>
                            </ul>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>
<!--========================== Privacy Policy Details Section End ==========================-->

<!--========================== Privacy FAQ Section ==========================-->
<section class="faq__area">
    <div class="faq__sp"><img src="~/assets/images/wave-sp.png" alt="img"></div>
    <div class="faq__sp sp2"><img src="~/assets/images/faq/sp1.png" alt="img"></div>
    <div class="faq__sp sp3"><img src="~/assets/images/faq/arrow.png" alt="img"></div>
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="faq__title" data-aos="flip-up" data-aos-delay="200" data-aos-duration="1200">
                    <h2>Privacy <span>Questions</span></h2>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <div class="faq__main__blk">
                    <div class="accordion" id="privacyAccordion">

                        <div class="accordion-item active">
                            <h2 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#pFaq1" aria-expanded="true" aria-controls="pFaq1">
                                    <span class="faq__plus faq__icon"><i class="fa-solid fa-plus"></i></span>
                                    <span class="faq__minus faq__icon"><i class="fa-solid fa-minus"></i></span>
                                    Do you store my card or UPI details?
                                </button>
                            </h2>
                            <div id="pFaq1" class="accordion-collapse collapse show" data-bs-parent="#privacyAccordion">
                                <div class="accordion-body">
                                    No. We do not store any card, UPI, or net banking credentials on our servers.
                                    All payment information is processed directly through our certified payment gateway partners
                                    and is never retained by MobiCharge.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#pFaq2" aria-expanded="false" aria-controls="pFaq2">
                                    <span class="faq__plus faq__icon"><i class="fa-solid fa-plus"></i></span>
                                    <span class="faq__minus faq__icon"><i class="fa-solid fa-minus"></i></span>
                                    Can I request deletion of my account data?
                                </button>
                            </h2>
                            <div id="pFaq2" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                                <div class="accordion-body">
                                    Yes. You can contact our support team at support@yoursite.com to request deletion of your
                                    account and associated data. We will process all deletion requests within 7 business days.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#pFaq3" aria-expanded="false" aria-controls="pFaq3">
                                    <span class="faq__plus faq__icon"><i class="fa-solid fa-plus"></i></span>
                                    <span class="faq__minus faq__icon"><i class="fa-solid fa-minus"></i></span>
                                    Is my mobile number shared with operators?
                                </button>
                            </h2>
                            <div id="pFaq3" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                                <div class="accordion-body">
                                    Your mobile number is shared only with the relevant telecom operator solely
                                    for the purpose of processing your recharge or bill payment. It is not used for
                                    any marketing or promotional activity.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#pFaq4" aria-expanded="false" aria-controls="pFaq4">
                                    <span class="faq__plus faq__icon"><i class="fa-solid fa-plus"></i></span>
                                    <span class="faq__minus faq__icon"><i class="fa-solid fa-minus"></i></span>
                                    Do you use cookies?
                                </button>
                            </h2>
                            <div id="pFaq4" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                                <div class="accordion-body">
                                    Yes, we use essential session cookies to keep you logged in and to process
                                    transactions securely. We do not use tracking or advertising cookies.
                                    You can manage cookie preferences through your browser settings.
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!--========================== Privacy FAQ Section End ==========================-->

<!--========================== Contact CTA Section ==========================-->
<section class="counter__area">
    @* <div class="counter__sp"><img src="~/assets/images/green-sp.png" alt="img"></div> *@
    <div class="container-fluid p-0">
        <div class="counter__main">
            <div class="counter__main__single">
                <h4><span class="counter__stroke">🔒</span></h4>
                <p>Encrypted Transactions</p>
            </div>
            <div class="counter__main__single">
                <h4><span class="counter__stroke">🚫</span></h4>
                <p>No Data Selling</p>
            </div>
            <div class="counter__main__single">
                <h4><span class="counter__stroke">✅</span></h4>
                <p>GDPR Compliant Practices</p>
            </div>
        </div>
    </div>
</section>
<!--========================== CTA Section End ==========================-->
