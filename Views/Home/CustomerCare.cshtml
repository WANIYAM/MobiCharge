@{
    ViewData["Title"] = "Customer Care";
}

<!--========================== Banner Section Start ==========================-->
<section class="banner__area">
    @* <div class="banner__bg"><img src="~/assets/images/banner-bg.png" alt="img"></div> *@
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="banner__topbar">
                    <div class="banner__title">
                        <h2>We're Here to <span>Help You!</span></h2>
                    </div>
                    <div class="banner__btn">
                        <a href="/" class="common__btn"><span>Back to Home</span><span><i class="fa-solid fa-arrow-right"></i></span></a>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <div class="banner__thumb">
                    <video autoplay muted loop>
                        <source src="~/assets/images/banner-thumb.mp4" type="video/mp4">
                    </video>
                </div>
            </div>
        </div>
    </div>
</section>
<!--========================== Banner Section End ==========================-->

<!--========================== Customer Care Intro Section Start ==========================-->
<section class="about__details">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="about__details__wrap">
                    <div class="about__details__label">
                        <div class="footer__subs__label about-label">
                            <div class="footer__subs__shr">
                                <img src="~/assets/images/about/label-sp.png" alt="img">
                                <div class="footer__circle__text">
                                    <p>Available 24/7 for all your recharge &amp; payment needs.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="about__details__content">
                        <h5>
                            Our dedicated customer care team is available round the clock to assist you with any
                            recharge, bill payment, or account-related issue. Reach us through phone, WhatsApp,
                            or email — whichever is most convenient for you.
                        </h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!--========================== Customer Care Intro Section End ==========================-->

<!--========================== Contact Channels Section Start ==========================-->
<section class="about__feature" style="padding: 80px 0;">
    @* <div class="about__fsp"><img src="~/assets/images/yellow-sp.png" alt="img"></div> *@
    <div class="about__fsp2"><img src="~/assets/images/circle-sp.png" alt="img"></div>
    <div class="about__fsp3"><img src="~/assets/images/wave-sp.png" alt="img"></div>

    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="feature__title">
                    <h2 data-aos="fade-up-left" data-aos-delay="200" data-aos-duration="1200">
                        Contact <span>Channels</span>
                    </h2>
                    <a href="/Recharge" class="common__btn" data-aos="fade-down-right" data-aos-delay="200" data-aos-duration="1200">
                        <span>Recharge Now</span><span><i class="fa-solid fa-arrow-right"></i></span>
                    </a>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <div class="about__feature__wrap">

                    <!-- Toll Free -->
                    <div class="about__feature__wrap__single">
                        <div class="about__feature__wrap__single__title">
                            <h4><i class="fa-solid fa-phone" style="font-size:1.4rem;"></i><br>Toll Free</h4>
                        </div>
                        <div class="about__feature__wrap__single__content">
                            <p>
                                Call our toll-free helpline any time of day or night.
                                Our agents are available 24/7 to resolve your recharge
                                and payment queries instantly.
                            </p>
                            <ul>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>1800-XXX-XXXX</li>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Available 24 / 7</li>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Zero call charges</li>
                            </ul>
                        </div>
                    </div>

                    <!-- WhatsApp -->
                    <div class="about__feature__wrap__single">
                        <div class="about__feature__wrap__single__title">
                            <h4><i class="fa-brands fa-whatsapp" style="font-size:1.4rem;"></i><br>WhatsApp</h4>
                        </div>
                        <div class="about__feature__wrap__single__content">
                            <p>
                                Prefer messaging? Chat with our support team directly
                                on WhatsApp. Send your query and get a reply within
                                minutes — no waiting on hold.
                            </p>
                            <ul>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>+92 300 1234567</li>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Quick response time</li>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Share screenshots easily</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="about__feature__wrap__single">
                        <div class="about__feature__wrap__single__title">
                            <h4><i class="fa-solid fa-envelope" style="font-size:1.4rem;"></i><br>Email Support</h4>
                        </div>
                        <div class="about__feature__wrap__single__content">
                            <p>
                                For detailed queries, complaints, or receipt requests,
                                email our support team. We respond to all emails
                                within 24 hours on business days.
                            </p>
                            <ul>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>support@yoursite.com</li>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Response within 24 hrs</li>
                                <li><span><img src="~/assets/images/about/star.png" alt="img"></span>Mon – Sat, 9 AM – 7 PM</li>
                            </ul>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>
<!--========================== Contact Channels Section End ==========================-->

<!--========================== Working Hours & Counter Section ==========================-->
<section class="counter__area">
    @* <div class="counter__sp"><img src="~/assets/images/green-sp.png" alt="img"></div> *@
    <div class="container-fluid p-0">
        <div class="counter__main">
            <div class="counter__main__single">
                <h4><span class="counter">24</span><span class="counter__stroke">/7</span></h4>
                <p>Support Available</p>
            </div>
            <div class="counter__main__single">
                <h4><span class="counter">60</span><span class="counter__stroke">sec</span></h4>
                <p>Avg. Response Time</p>
            </div>
            <div class="counter__main__single">
                <h4><span class="counter">99</span><span class="counter__stroke">%</span></h4>
                <p>Issues Resolved</p>
            </div>
        </div>
    </div>
</section>
<!--========================== Counter Section End ==========================-->

<!--========================== FAQ Section ==========================-->
<section class="faq__area">
    <div class="faq__sp"><img src="~/assets/images/wave-sp.png" alt="img"></div>
    <div class="faq__sp sp2"><img src="~/assets/images/faq/sp1.png" alt="img"></div>
    <div class="faq__sp sp3"><img src="~/assets/images/faq/arrow.png" alt="img"></div>
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="faq__title" data-aos="flip-up" data-aos-delay="200" data-aos-duration="1200">
                    <h2>Common Support <span>Questions</span></h2>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <div class="faq__main__blk">
                    <div class="accordion" id="ccFaqAccordion">

                        <div class="accordion-item active">
                            <h2 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#ccFaq1" aria-expanded="true" aria-controls="ccFaq1">
                                    <span class="faq__plus faq__icon"><i class="fa-solid fa-plus"></i></span>
                                    <span class="faq__minus faq__icon"><i class="fa-solid fa-minus"></i></span>
                                    My recharge was deducted but not applied. What should I do?
                                </button>
                            </h2>
                            <div id="ccFaq1" class="accordion-collapse collapse show" data-bs-parent="#ccFaqAccordion">
                                <div class="accordion-body">
                                    Please wait up to 15 minutes as recharges can sometimes be delayed. If the balance is still not credited,
                                    note your Transaction ID from the receipt and contact us via phone or WhatsApp. Our team will resolve it within 2 hours.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ccFaq2" aria-expanded="false" aria-controls="ccFaq2">
                                    <span class="faq__plus faq__icon"><i class="fa-solid fa-plus"></i></span>
                                    <span class="faq__minus faq__icon"><i class="fa-solid fa-minus"></i></span>
                                    How do I get a copy of my payment receipt?
                                </button>
                            </h2>
                            <div id="ccFaq2" class="accordion-collapse collapse" data-bs-parent="#ccFaqAccordion">
                                <div class="accordion-body">
                                    A receipt is generated automatically after every successful payment. You can print it directly from the confirmation page.
                                    If you missed it, log in to My Account and check your transaction history to reprint.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ccFaq3" aria-expanded="false" aria-controls="ccFaq3">
                                    <span class="faq__plus faq__icon"><i class="fa-solid fa-plus"></i></span>
                                    <span class="faq__minus faq__icon"><i class="fa-solid fa-minus"></i></span>
                                    I forgot my account password. How do I reset it?
                                </button>
                            </h2>
                            <div id="ccFaq3" class="accordion-collapse collapse" data-bs-parent="#ccFaqAccordion">
                                <div class="accordion-body">
                                    Click on "Forgot Password" on the login page and enter your registered mobile number or email.
                                    You will receive a reset link. If you face any trouble, contact our support team via WhatsApp or email.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ccFaq4" aria-expanded="false" aria-controls="ccFaq4">
                                    <span class="faq__plus faq__icon"><i class="fa-solid fa-plus"></i></span>
                                    <span class="faq__minus faq__icon"><i class="fa-solid fa-minus"></i></span>
                                    Can I cancel a recharge after payment?
                                </button>
                            </h2>
                            <div id="ccFaq4" class="accordion-collapse collapse" data-bs-parent="#ccFaqAccordion">
                                <div class="accordion-body">
                                    Recharge transactions are processed instantly and cannot be cancelled once confirmed.
                                    If the wrong number was recharged by mistake, please contact our team immediately with your Transaction ID and we will do our best to assist.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ccFaq5" aria-expanded="false" aria-controls="ccFaq5">
                                    <span class="faq__plus faq__icon"><i class="fa-solid fa-plus"></i></span>
                                    <span class="faq__minus faq__icon"><i class="fa-solid fa-minus"></i></span>
                                    What payment methods are supported?
                                </button>
                            </h2>
                            <div id="ccFaq5" class="accordion-collapse collapse" data-bs-parent="#ccFaqAccordion">
                                <div class="accordion-body">
                                    We support Credit Card, Debit Card, Net Banking, and UPI. All transactions are encrypted and secure.
                                    A unique Transaction ID is generated for every successful payment for your records.
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!--========================== FAQ Section End ==========================-->

<!--========================== Testimonial Section ==========================-->
