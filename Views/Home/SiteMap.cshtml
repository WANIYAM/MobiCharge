@{
    ViewData["Title"] = "Site Map";
}

<!--========================== Banner Section Start ==========================-->
<section class="banner__area">
    @* <div class="banner__bg"><img src="~/assets/images/banner-bg.png" alt="img"></div> *@
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="banner__topbar">
                    <div class="banner__title">
                        <h2>Explore Our <span>Site Map</span></h2>
                    </div>
                    <div class="banner__btn">
                        <a href="/" class="common__btn"><span>Back to Home</span><span><i class="fa-solid fa-arrow-right"></i></span></a>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <div class="banner__thumb">
                    <video autoplay muted loop>
                        <source src="~/assets/images/banner-thumb.mp4" type="video/mp4">
                    </video>
                </div>
            </div>
        </div>
    </div>
</section>
<!--========================== Banner Section End ==========================-->

<!--========================== Site Map Links Section ==========================-->
<section class="about__feature" style="padding: 80px 0;">
    @* <div class="about__fsp"><img src="~/assets/images/yellow-sp.png" alt="img"></div> *@
    <div class="about__fsp2"><img src="~/assets/images/circle-sp.png" alt="img"></div>
    <div class="about__fsp3"><img src="~/assets/images/wave-sp.png" alt="img"></div>

    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="feature__title">
                    <h2 data-aos="fade-up-left" data-aos-delay="200" data-aos-duration="1200">
                        All Pages at a <span>Glance</span>
                    </h2>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <div class="about__feature__wrap">

                    <!-- Main Pages -->
                    <div class="about__feature__wrap__single">
                        <div class="about__feature__wrap__single__title">
                            <h4>Main <br>Pages</h4>
                        </div>
                        <div class="about__feature__wrap__single__content">
                            <p>Core pages of the portal that every visitor can access without logging in.</p>
                            <ul>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/">Home</a>
                                </li>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/Home/About">About Us</a>
                                </li>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/Home/Contact">Contact Us</a>
                                </li>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/Home/CustomerCare">Customer Care</a>
                                </li>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/Feedback">Feedback</a>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Recharge Services -->
                    <div class="about__feature__wrap__single">
                        <div class="about__feature__wrap__single__title">
                            <h4>Recharge <br>Services</h4>
                        </div>
                        <div class="about__feature__wrap__single__content">
                            <p>Recharge and bill payment services available to both guests and registered users.</p>
                            <ul>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/Recharge">Online Recharge</a>
                                </li>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/Recharge">Top Up Recharge</a>
                                </li>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/Recharge">Special Recharge</a>
                                </li>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/Recharge/Postpaid">Post Bill Payment</a>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Account & Admin -->
                    <div class="about__feature__wrap__single">
                        <div class="about__feature__wrap__single__title">
                            <h4>Account &amp; <br>Access</h4>
                        </div>
                        <div class="about__feature__wrap__single__content">
                            <p>Account management and authentication pages for registered users and administrators.</p>
                            <ul>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/Identity/Account/Register">Register</a>
                                </li>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/Identity/Account/Login">Login</a>
                                </li>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/MyAccount">My Account</a>
                                </li>
                                <li>
                                    <span><img src="~/assets/images/about/star.png" alt="img"></span>
                                    <a href="/Home/SiteMap">Site Map</a>
                                </li>
                            </ul>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>
<!--========================== Site Map Links Section End ==========================-->

<!--========================== Counter Section ==========================-->
<section class="counter__area">
    @* <div class="counter__sp"><img src="~/assets/images/green-sp.png" alt="img"></div> *@
    <div class="container-fluid p-0">
        <div class="counter__main">
            <div class="counter__main__single">
                <h4><span class="counter">10</span><span class="counter__stroke">+</span></h4>
                <p>Total Pages</p>
            </div>
            <div class="counter__main__single">
                <h4><span class="counter">5</span><span class="counter__stroke">+</span></h4>
                <p>Recharge Services</p>
            </div>
            <div class="counter__main__single">
                <h4><span class="counter">24</span><span class="counter__stroke">/7</span></h4>
                <p>Always Online</p>
            </div>
        </div>
    </div>
</section>
<!--========================== Counter Section End ==========================-->
