@model MobileRechargeApp.Models.EditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

<section class="account-area">
    <div class="container" style="padding-top: 140px; padding-bottom: 60px;">

        <!-- Breadcrumb -->
        <div class="hero__wrap__users" style="margin-bottom: 30px; justify-content: flex-start;" data-aos="fade-up">
            <div class="hero__wrap__users__img">
                <span><img src="~/assets/images/hero/user-1.jpg" alt="user"></span>
                <span><img src="~/assets/images/hero/user-2.jpg" alt="user"></span>
                <span><img src="~/assets/images/hero/user-3.jpg" alt="user"></span>
                <span><img src="~/assets/images/hero/user-4.jpg" alt="user"></span>
            </div>
            <div class="hero__wrap__users__title">
                <span>
                    <a href="/MyAccount" style="color: inherit; text-decoration: none;">My Account</a>
                    <i class="las la-angle-right" style="margin: 0 10px;"></i>
                    Edit Profile
                </span>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-7">

                <!-- Main Card -->
                <div class="transactions-panel">
                    
                    <div class="panel-header">
                        <h5 class="mb-0">
                            <i class="las la-user-edit" style="color: hsl(var(--base));"></i>
                            Edit Personal Details
                        </h5>
                        <div class="happy-users-badge" style="padding: 0.25rem 1rem;">
                            <i class="las la-user"></i>
                            <span>Profile Settings</span>
                        </div>
                    </div>

                    <div class="p-4">

                        @if (ViewBag.Success != null)
                        {
                            <div class="alert mb-4" style="background: hsl(var(--base) / 0.1); border-left: 4px solid hsl(var(--base)); border-radius: 12px;">
                                <i class="las la-check-circle" style="color: hsl(var(--base));"></i>
                                @ViewBag.Success
                            </div>
                        }

                        <div asp-validation-summary="ModelOnly" class="alert mb-4" style="background: hsl(var(--danger) / 0.1); border-left: 4px solid hsl(var(--danger)); border-radius: 12px; color: hsl(var(--danger));">
                        </div>

                        <form asp-action="EditProfile" method="post">

                            <!-- Mobile Number (readonly) -->
                            <div class="mb-4">
                                <label class="form-label fw-bold mb-2">
                                    <i class="las la-mobile-alt" style="color: hsl(var(--base));"></i>
                                    Mobile Number (Username)
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text" style="background: hsl(var(--section-bg)); border: 1px solid hsl(var(--border-color)); border-right: none;">
                                        <i class="las la-phone"></i>
                                    </span>
                                    <input asp-for="MobileNumber" class="form-control" readonly
                                           style="background: hsl(var(--section-bg)); border: 1px solid hsl(var(--border-color));" />
                                </div>
                                <small class="text-muted">Mobile number cannot be changed</small>
                            </div>

                            <!-- Full Name -->
                            <div class="mb-4">
                                <label asp-for="FullName" class="form-label fw-bold mb-2">
                                    <i class="las la-user" style="color: hsl(var(--base));"></i>
                                    Full Name
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text" style="background: hsl(var(--section-bg)); border: 1px solid hsl(var(--border-color)); border-right: none;">
                                        <i class="las la-user-circle"></i>
                                    </span>
                                    <input asp-for="FullName" class="form-control" placeholder="Enter your full name"
                                           style="border: 1px solid hsl(var(--border-color));" />
                                </div>
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <!-- Phone Number -->
                            <div class="mb-4">
                                <label asp-for="PhoneNumber" class="form-label fw-bold mb-2">
                                    <i class="las la-phone" style="color: hsl(var(--base));"></i>
                                    Alternate Phone Number
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text" style="background: hsl(var(--section-bg)); border: 1px solid hsl(var(--border-color)); border-right: none;">
                                        <i class="las la-phone-alt"></i>
                                    </span>
                                    <input asp-for="PhoneNumber" class="form-control" placeholder="Enter alternate number" maxlength="10"
                                           style="border: 1px solid hsl(var(--border-color));" />
                                </div>
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>

                            <div class="brand__title" style="margin: 30px 0 20px;">
                                <span class="brand__line"></span>
                                <h6 style="margin: 0 20px; font-size: 1rem;">
                                    <i class="las la-lock" style="color: hsl(var(--base));"></i>
                                    Change Password (Optional)
                                </h6>
                                <span class="brand__line"></span>
                            </div>

                            <!-- New Password -->
                            <div class="mb-4">
                                <label asp-for="NewPassword" class="form-label fw-bold mb-2">
                                    <i class="las la-key" style="color: hsl(var(--base));"></i>
                                    New Password
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text" style="background: hsl(var(--section-bg)); border: 1px solid hsl(var(--border-color)); border-right: none;">
                                        <i class="las la-lock"></i>
                                    </span>
                                    <input asp-for="NewPassword" class="form-control"
                                           placeholder="Leave blank to keep current password"
                                           autocomplete="new-password"
                                           style="border: 1px solid hsl(var(--border-color));" />
                                </div>
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>

                            <!-- Confirm Password -->
                            <div class="mb-4">
                                <label asp-for="ConfirmPassword" class="form-label fw-bold mb-2">
                                    <i class="las la-lock" style="color: hsl(var(--base));"></i>
                                    Confirm New Password
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text" style="background: hsl(var(--section-bg)); border: 1px solid hsl(var(--border-color)); border-right: none;">
                                        <i class="las la-check-circle"></i>
                                    </span>
                                    <input asp-for="ConfirmPassword" class="form-control"
                                           placeholder="Re-enter new password"
                                           autocomplete="new-password"
                                           style="border: 1px solid hsl(var(--border-color));" />
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <div class="d-flex gap-3 mt-4">
                                <button type="submit" class="btn-view" style="background: linear-gradient(135deg, hsl(var(--base)), hsl(var(--base-two))); color: white; border: none; padding: 0.75rem 2rem;">
                                    <i class="las la-save"></i>
                                    Save Changes
                                </button>
                                <a href="/MyAccount" class="btn-view" style="background: transparent; border: 1px solid hsl(var(--border-color)); color: hsl(var(--text-color));">
                                    <i class="las la-times"></i>
                                    Cancel
                                </a>
                            </div>

                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}