@model IEnumerable<MobileRechargeApp.Models.SpecialPlan>
@{
    ViewData["Title"] = "Special Plans";
    Layout = "_AdminLayout";
}

@if (TempData["Success"] != null)
{
    <div class="alert-modern alert-success">
        <i class="las la-check-circle"></i>
        <span>@TempData["Success"]</span>
    </div>
}

<!-- Page Header -->
<div class="plans-header">
    <div class="plans-header-left">
        <div class="plans-header-icon special-icon">
            <i class="las la-star"></i>
        </div>
        <div>
            <h1 class="plans-header-title">Special Recharge Plans</h1>
            <p class="plans-header-subtitle">Manage all special combo plans with benefits</p>
        </div>
    </div>
    <a href="/Admin/AddSpecialPlan" class="btn-add">
        <i class="las la-plus-circle"></i>
        <span>Add New Plan</span>
    </a>
</div>

<!-- Plans Grid -->
<div class="plans-grid">
    @if (!Model.Any())
    {
        <div class="empty-state full-width">
            <i class="las la-star"></i>
            <h3>No Special Plans Found</h3>
            <p>Get started by adding your first special plan</p>
            <a href="/Admin/AddSpecialPlan" class="btn-add empty-btn">
                <i class="las la-plus-circle"></i>
                Add New Plan
            </a>
        </div>
    }
    else
    {
        @foreach (var plan in Model)
        {
            <div class="plan-card special-card">
                <div class="plan-card-header">
                    <div class="plan-icon special-icon">
                        <i class="las la-star"></i>
                    </div>
                    <span class="plan-id">#@plan.PlanId</span>
                </div>
                
                <div class="plan-card-body">
                    <div class="plan-amount">Rs. @plan.Amount</div>
                    <p class="plan-description">@plan.Description</p>
                    
                    <div class="plan-details">
                        <div class="plan-detail-item">
                            <span class="detail-label">Validity</span>
                            <span class="detail-value">@plan.Validity Days</span>
                        </div>
                        <div class="plan-detail-item">
                            <span class="detail-label">Benefits</span>
                            <span class="detail-value">@plan.Benefits</span>
                        </div>
                    </div>
                </div>
                
                <div class="plan-card-footer">
                    <a href="/Admin/EditSpecialPlan/@plan.PlanId" class="btn-edit">
                        <i class="las la-edit"></i>
                        <span>Edit</span>
                    </a>
                    <a href="/Admin/DeleteSpecialPlan/@plan.PlanId" class="btn-delete"
                       onclick="return confirm('Are you sure you want to delete this plan?')">
                        <i class="las la-trash"></i>
                        <span>Delete</span>
                    </a>
                </div>
            </div>
        }
    }
</div>

<style>
    /* ===== MODERN PLANS PAGE STYLES ===== */
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', sans-serif;
        background: #f8fafc;
        color: #1e293b;
    }

    /* Alert Styles */
    .alert-modern {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px 20px;
        border-radius: 16px;
        margin-bottom: 24px;
        font-weight: 500;
        animation: slideDown 0.3s ease;
        border-left: 4px solid;
    }

    .alert-success {
        background: #e8f5e9;
        border-left-color: #2e7d32;
        color: #1b5e20;
    }

    .alert-modern i {
        font-size: 20px;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Header Styles */
    .plans-header {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-bottom: 32px;
        animation: fadeIn 0.5s ease;
    }

    .plans-header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .plans-header-icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: white;
        flex-shrink: 0;
    }

    .special-icon {
        background: linear-gradient(135deg, #f97316, #f59e0b);
        box-shadow: 0 10px 20px -5px #f97316;
    }

    .plans-header-title {
        font-size: 24px;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }

    .plans-header-subtitle {
        font-size: 14px;
        color: #64748b;
        margin: 4px 0 0;
    }

    .btn-add {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 24px;
        background: linear-gradient(135deg, #00bcd4, #0097a7);
        color: white;
        border-radius: 40px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        width: 100%;
    }

    .btn-add:hover {
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px -5px #00bcd4;
    }

    /* Plans Grid */
    .plans-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
        animation: fadeInUp 0.5s ease;
    }

    /* Plan Card */
    .plan-card {
        background: white;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .plan-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 30px -10px rgba(0, 188, 212, 0.2);
        border-color: #00bcd4;
    }

    .special-card:hover {
        border-color: #f97316;
    }

    .special-card:hover .plan-card-header .plan-icon {
        transform: scale(1.1) rotate(5deg);
    }

    .plan-card-header {
        padding: 20px;
        background: linear-gradient(135deg, #f8fafc, white);
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .plan-icon {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        transition: all 0.3s ease;
    }

    .plan-id {
        padding: 6px 16px;
        background: #e2e8f0;
        color: #475569;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 600;
    }

    .plan-card-body {
        padding: 20px;
    }

    .plan-amount {
        font-size: 32px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 8px;
        line-height: 1.2;
    }

    .special-card .plan-amount {
        color: #f97316;
    }

    .plan-description {
        color: #64748b;
        font-size: 14px;
        margin-bottom: 20px;
        line-height: 1.5;
    }

    .plan-details {
        display: flex;
        gap: 24px;
        padding: 16px;
        background: #f8fafc;
        border-radius: 16px;
    }

    .plan-detail-item {
        flex: 1;
    }

    .detail-label {
        display: block;
        font-size: 12px;
        color: #94a3b8;
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .detail-value {
        display: block;
        font-size: 16px;
        font-weight: 600;
        color: #0f172a;
    }

    .plan-card-footer {
        padding: 20px;
        background: #f8fafc;
        border-top: 1px solid #e2e8f0;
        display: flex;
        gap: 12px;
    }

    .btn-edit, .btn-delete {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 10px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        border: 1px solid transparent;
    }

    .btn-edit {
        background: #e0f2f1;
        color: #0097a7;
    }

    .btn-edit:hover {
        background: #0097a7;
        color: white;
        transform: translateY(-2px);
    }

    .btn-delete {
        background: #ffebee;
        color: #c62828;
    }

    .btn-delete:hover {
        background: #c62828;
        color: white;
        transform: translateY(-2px);
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px 24px;
        background: white;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
    }

    .empty-state i {
        font-size: 64px;
        color: #00bcd4;
        opacity: 0.3;
        margin-bottom: 20px;
    }

    .empty-state h3 {
        font-size: 20px;
        color: #0f172a;
        margin-bottom: 8px;
    }

    .empty-state p {
        color: #64748b;
        margin-bottom: 24px;
    }

    .empty-btn {
        display: inline-flex;
        width: auto;
        padding: 12px 32px;
    }

    .full-width {
        grid-column: 1 / -1;
    }

    /* Animations */
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Tablet Styles */
    @@media (min-width: 768px) {
        .plans-header {
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }

        .plans-header-icon {
            width: 64px;
            height: 64px;
            font-size: 32px;
            border-radius: 20px;
        }

        .plans-header-title {
            font-size: 28px;
        }

        .btn-add {
            width: auto;
        }

        .plans-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* Desktop Styles */
    @@media (min-width: 1024px) {
        .plans-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    /* Large Desktop */
    @@media (min-width: 1400px) {
        .plans-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }
</style>