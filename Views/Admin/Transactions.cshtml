<script>
    (function() {
        let page = 1;

        function getPerPage() {
            return parseInt(document.getElementById('perPageSelect').value) || 10;
        }

        function isMobile() {
            return window.innerWidth < 1024;
        }

        function getItems() {
            if (isMobile()) {
                return Array.from(document.querySelectorAll('#mobile-rows .transaction-card'));
            } else {
                return Array.from(document.querySelectorAll('#desktop-rows .transaction-row'));
            }
        }

        function initPagination() {
            page = 1;
            render();
        }

        function render() {
            const pp = getPerPage();
            const items = getItems();
            const total = items.length;
            const pages = Math.max(1, Math.ceil(total / pp));
        
            if (page > pages) page = pages;

            const from = (page - 1) * pp;
            const to = Math.min(from + pp, total);

            items.forEach((item, index) => {
                item.style.display = (index >= from && index < to) ? '' : 'none';
            });

            const summaryEl = document.getElementById('pg-summary');
            if (summaryEl) {
                summaryEl.textContent = total === 0
                    ? 'No records'
                    : `Showing ${from + 1}–${to} of ${total} transactions`;
            }

            const labelEl = document.getElementById('page-label');
            if (labelEl) {
                labelEl.textContent = total > 0 ? `Page ${page}/${pages}` : '';
            }

            const barEl = document.getElementById('pg-bar');
            if (barEl) {
                barEl.style.display = (pages <= 1 && total <= pp) ? 'none' : 'flex';
            }

            buildPaginationButtons(pages);
        }

        function buildPaginationButtons(pages) {
            const container = document.getElementById('pg-btns');
            if (!container) return;

            container.innerHTML = '';

            const prevBtn = createButton('‹', 'pg-btn pg-btn--nav', page === 1);
            prevBtn.onclick = () => {
                if (page > 1) {
                    page--;
                    render();
                }
            };
            container.appendChild(prevBtn);

            const pageNumbers = getPageNumbers(page, pages);
            pageNumbers.forEach(p => {
                if (p === '…') {
                    const dots = document.createElement('span');
                    dots.className = 'pg-dots';
                    dots.textContent = '…';
                    container.appendChild(dots);
                } else {
                    const btn = createButton(p, 'pg-btn' + (p === page ? ' pg-btn--on' : ''), false);
                    btn.onclick = () => {
                        page = p;
                        render();
                    };
                    container.appendChild(btn);
                }
            });

            const nextBtn = createButton('›', 'pg-btn pg-btn--nav', page === pages);
            nextBtn.onclick = () => {
                if (page < pages) {
                    page++;
                    render();
                }
            };
            container.appendChild(nextBtn);
        }

        function createButton(text, className, disabled) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.innerHTML = text;
            btn.className = className;
            btn.disabled = disabled;
            return btn;
        }

        function getPageNumbers(current, total) {
            if (total <= 7) {
                return Array.from({ length: total }, (_, i) => i + 1);
            }
        
            const pages = new Set([1, total, current]);
            if (current > 1) pages.add(current - 1);
            if (current < total) pages.add(current + 1);
        
            const sorted = [...pages].sort((a, b) => a - b);
            const result = [];
            let prev = 0;
        
            sorted.forEach(num => {
                if (num - prev > 1) result.push('…');
                result.push(num);
                prev = num;
            });
        
            return result;
        }

        let resizeTimer;
        window.addEventListener('resize', function() {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(render, 100);
        });

        document.addEventListener('DOMContentLoaded', render);
        window.initPagination = initPagination;
    })();
</script>
