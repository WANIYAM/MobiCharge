@model IEnumerable<MobileRechargeApp.Models.Transaction>
@{
    ViewData["Title"] = "All Transactions";
    Layout = "_AdminLayout";
}

@if (TempData["Success"] != null)
{
    <div style="background:hsl(var(--base)/0.1);border-left:4px solid hsl(var(--base));border-radius:12px;padding:12px 18px;margin-bottom:20px;color:hsl(var(--base));display:flex;align-items:center;gap:10px;">
        <i class="las la-check-circle"></i> @TempData["Success"]
    </div>
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1" style="font-family: 'ClashDisplay-Variable', sans-serif;">
            <i class="las la-exchange-alt" style="color: hsl(var(--base));"></i>
            All Transactions
        </h2>
        <p class="text-muted mb-0">Monitor all recharge and bill payments</p>
    </div>
    <span class="happy-users-badge" style="padding: 0.5rem 1.5rem;">
        <i class="las la-list"></i>
        <span>@Model.Count() Records</span>
    </span>
</div>

<!-- Date Filter Card -->
<div class="quick-stat-card mb-4" style="flex-direction: column; align-items: stretch;">
    <form method="get" class="d-flex gap-3 align-items-center flex-wrap">
        <div class="d-flex align-items-center gap-2">
            <i class="las la-calendar" style="color: hsl(var(--base)); font-size: 1.25rem;"></i>
            <span class="fw-bold">Filter by Date:</span>
        </div>
        <input type="date" name="date" value="@ViewBag.FilterDate"
               class="form-control" style="max-width:200px; border: 1px solid hsl(var(--border-color));" />
        <button type="submit" class="btn-view" style="background: linear-gradient(135deg, hsl(var(--base)), hsl(var(--base-two))); color: white; border: none;">
            <i class="las la-search"></i> Filter
        </button>
        <a href="/Admin/Transactions" class="btn-view" style="background: hsl(var(--section-bg)); color: hsl(var(--text-color)); border: 1px solid hsl(var(--border-color));">
            <i class="las la-times"></i> Clear
        </a>
        @if (ViewBag.FilterDate != null)
        {
            <span class="text-muted small">
                Showing: <strong>@ViewBag.FilterDate</strong>
            </span>
        }
    </form>
</div>

<!-- Transactions Panel -->
<div class="transactions-panel">

    <!-- Panel header with per-page selector -->
    <div class="panel-header">
        <h5 class="mb-0">
            <i class="las la-history" style="color: hsl(var(--base));"></i>
            Transaction History
        </h5>
        <div class="pg-controls-top">
            <span class="pg-info-text">Show</span>
            <select id="perPageSelect" class="pg-per-page" onchange="initPagination()">
                <option value="5">5</option>
                <option value="10" selected>10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
            <span class="pg-info-text">per page</span>
            <span class="pg-page-label" id="page-label"></span>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Transaction ID</th>
                    <th>Mobile Number</th>
                    <th>Plan Type</th>
                    <th>Amount</th>
                    <th>Payment Method</th>
                    <th>Status</th>
                    <th>Date & Time</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="table-body">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">
                                <i class="las la-inbox"></i>
                                <p class="mt-2">No transactions found</p>
                            </div>
                        </td>
                    </tr>
                }
                @foreach (var t in Model)
                {
                    <tr class="pg-row">
                        <td data-label="Transaction ID">
                            <span class="txn-id">#TXN@(t.TxnId.ToString("D6"))</span>
                        </td>
                        <td data-label="Mobile Number">
                            <span class="mobile-number">
                                <i class="las la-phone-alt"></i> @t.MobileNumber
                            </span>
                        </td>
                        <td data-label="Plan Type">
                            @if (t.PlanType == "topup")
                            {
                                <span class="badge-custom badge-topup"><i class="las la-sim-card"></i> Top Up</span>
                            }
                            else if (t.PlanType == "special")
                            {
                                <span class="badge-custom badge-special"><i class="las la-star"></i> Special</span>
                            }
                            else
                            {
                                <span class="badge-custom badge-postpaid"><i class="las la-calendar"></i> Postpaid</span>
                            }
                        </td>
                        <td data-label="Amount">
                            <span class="amount">Rs. @t.Amount</span>
                        </td>
                        <td data-label="Payment Method">
                            <span><i class="las la-credit-card"></i> @t.PaymentMethod</span>
                        </td>
                        <td data-label="Status">
                            <span class="badge-custom badge-success">
                                <i class="las la-check-circle"></i> @t.Status
                            </span>
                        </td>
                        <td data-label="Date & Time">
                            <span><i class="las la-clock"></i> @t.TxnDate.ToString("dd-MM-yyyy HH:mm")</span>
                        </td>
                        <td data-label="Actions">
                            <form method="post" action="/Admin/DeleteTransaction" style="margin:0;"
                                  onsubmit="return confirm('Delete transaction #TXN@(t.TxnId.ToString("D6"))? This cannot be undone.');">
                                <input type="hidden" name="TxnId" value="@t.TxnId" />
                                <button type="submit" class="btn-delete-txn">
                                    <i class="las la-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ── Pagination footer ── -->
    <div class="pg-bar" id="pg-bar">
        <span class="pg-summary" id="pg-summary"></span>
        <div class="pg-btns" id="pg-btns"></div>
    </div>

    @if (Model.Any())
    {
        <div class="panel-header" style="border-top: 1px solid hsl(var(--border-color)); border-bottom: none;">
            <div class="d-flex justify-content-end w-100">
                <strong style="font-size: 1.1rem;">
                    Total Amount: Rs. @Model.Sum(t => t.Amount)
                </strong>
            </div>
        </div>
    }
</div>

<style>
    .btn-delete-txn { background:hsl(0 100% 50%/0.1);color:hsl(0 100% 45%);border:1px solid hsl(0 100% 50%/0.3);padding:5px 12px;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:5px;transition:0.2s; }
    .btn-delete-txn:hover { background:hsl(0 100% 50%);color:#fff; }

    /* ── per-page control ── */
    .pg-controls-top { display:flex; align-items:center; gap:6px; }
    .pg-info-text { font-size:12px; color:hsl(var(--text-color)/.6); font-weight:500; }
    .pg-per-page { border:1px solid hsl(var(--border-color)); border-radius:8px; padding:4px 8px; font-size:12px; background:hsl(var(--section-bg)); color:hsl(var(--heading-color)); cursor:pointer; outline:none; transition:.15s; }
    .pg-per-page:focus { border-color:hsl(var(--base)); }
    .pg-page-label { font-size:12px; font-weight:600; color:hsl(var(--text-color)/.5); margin-left:4px; }

    /* ── pagination bar ── */
    .pg-bar { display:flex; align-items:center; justify-content:space-between; padding:12px 20px; border-top:1px solid hsl(var(--border-color)/.5); background:hsl(var(--section-bg)); flex-wrap:wrap; gap:8px; }
    .pg-summary { font-size:12px; color:hsl(var(--text-color)/.55); font-weight:500; }
    .pg-btns { display:flex; align-items:center; gap:4px; flex-wrap:wrap; }

    /* ── page buttons ── */
    .pg-btn {
        display:inline-flex; align-items:center; justify-content:center;
        min-width:32px; height:32px; padding:0 8px;
        border-radius:8px; border:1px solid hsl(var(--border-color));
        background:hsl(var(--white)); color:hsl(var(--text-color));
        font-size:12px; font-weight:600; cursor:pointer; transition:all .18s;
    }
    .pg-btn:hover:not(:disabled):not(.pg-btn--on) {
        border-color:hsl(var(--base)); color:hsl(var(--base));
        background:hsl(var(--base)/.07);
    }
    .pg-btn--on {
        background:linear-gradient(135deg, hsl(var(--base)), hsl(var(--base-two)));
        color:#fff; border-color:transparent;
        box-shadow:0 3px 10px hsl(var(--base)/.3);
    }
    .pg-btn--nav { font-size:14px; }
    .pg-btn:disabled { opacity:.3; cursor:not-allowed; }
    .pg-dots { display:inline-flex; align-items:center; justify-content:center; min-width:32px; height:32px; font-size:13px; color:hsl(var(--text-color)/.35); }
</style>

<script>
(function () {
    let page = 1;

    const perPageEl  = () => document.getElementById('perPageSelect');
    const rows       = () => Array.from(document.querySelectorAll('#table-body .pg-row'));
    const perPage    = () => parseInt(perPageEl().value) || 10;

    function initPagination() { page = 1; render(); }

    function render() {
        const pp    = perPage();
        const all   = rows();
        const total = all.length;
        const pages = Math.max(1, Math.ceil(total / pp));
        if (page > pages) page = pages;

        const from = (page - 1) * pp;
        const to   = Math.min(from + pp, total);

        all.forEach((r, i) => r.style.display = (i >= from && i < to) ? '' : 'none');

        document.getElementById('pg-summary').textContent =
            total === 0 ? 'No records' : `Showing ${from + 1}–${to} of ${total} transactions`;

        document.getElementById('page-label').textContent =
            total > 0 ? `· Page ${page}/${pages}` : '';

        document.getElementById('pg-bar').style.display =
            (pages <= 1 && total <= pp) ? 'none' : 'flex';

        buildBtns(pages);
    }

    function buildBtns(pages) {
        const wrap = document.getElementById('pg-btns');
        wrap.innerHTML = '';

        const prev = mkBtn('&#8249;', 'pg-btn pg-btn--nav', page === 1);
        prev.onclick = () => { if (page > 1) { page--; render(); } };
        wrap.appendChild(prev);

        pageNums(page, pages).forEach(p => {
            if (p === '…') {
                const d = document.createElement('span');
                d.className = 'pg-dots'; d.textContent = '…';
                wrap.appendChild(d);
            } else {
                const b = mkBtn(p, 'pg-btn' + (p === page ? ' pg-btn--on' : ''), false);
                b.onclick = () => { page = p; render(); };
                wrap.appendChild(b);
            }
        });

        const next = mkBtn('&#8250;', 'pg-btn pg-btn--nav', page === pages);
        next.onclick = () => { if (page < pages) { page++; render(); } };
        wrap.appendChild(next);
    }

    function mkBtn(html, cls, disabled) {
        const b = document.createElement('button');
        b.type = 'button'; b.innerHTML = html;
        b.className = cls; b.disabled = disabled;
        return b;
    }

    function pageNums(cur, total) {
        if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
        const set = new Set([1, total, cur]);
        if (cur > 1) set.add(cur - 1);
        if (cur < total) set.add(cur + 1);
        const sorted = [...set].sort((a, b) => a - b);
        const out = []; let prev = 0;
        sorted.forEach(n => { if (n - prev > 1) out.push('…'); out.push(n); prev = n; });
        return out;
    }

    document.addEventListener('DOMContentLoaded', render);
    window.initPagination = initPagination;
})();
</script>
