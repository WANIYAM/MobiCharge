@model MobileRechargeApp.Models.CreateUserViewModel
@{
    ViewData["Title"] = "Create User";
    Layout = "_AdminLayout";
}

@if (TempData["Success"] != null)
{
    <div class="alert-modern alert-success">
        <i class="las la-check-circle"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-modern alert-error">
        <i class="las la-exclamation-circle"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<!-- ── Page Header ─────────────────────────────────────────────── -->
<div class="create-page-header">
    <div class="create-page-header__left">
        <div class="create-page-header__icon">
            <i class="las la-user-plus"></i>
        </div>
        <div class="create-page-header__text">
            <h1 class="create-page-header__title">Create New User</h1>
            <p class="create-page-header__subtitle">Add a new user account to the platform</p>
        </div>
    </div>
    <div class="create-page-header__right">
        <a href="/Admin/Users" class="btn btn-outline">
            <i class="las la-arrow-left"></i>
            <span>Back to Users</span>
        </a>
    </div>
</div>

<!-- ── Main Form Card ──────────────────────────────────────────── -->
<div class="create-form-container">
    <div class="create-form-card">
        <!-- Card Header -->
        <div class="create-form-card__header">
            <div class="create-form-card__header-left">
                <span class="create-form-card__dot"></span>
                <h3 class="create-form-card__title">New User Information</h3>
            </div>
            <span class="create-form-card__badge">Create Mode</span>
        </div>

        <!-- Card Body -->
        <div class="create-form-card__body">
            <form asp-action="CreateUser" method="post" class="create-form">
                <div asp-validation-summary="All" class="form-validation-summary"></div>

                <!-- Form Grid - 2 columns on desktop -->
                <div class="create-form-grid">
                    <!-- Left Column -->
                    <div class="create-form-grid__col">
                        <!-- Full Name -->
                        <div class="create-form-group">
                            <label class="create-form-label">
                                <span>Full Name</span>
                                <span class="create-form-label__required">*</span>
                            </label>
                            <div class="create-input-wrapper">
                                <span class="create-input-icon">
                                    <i class="las la-user"></i>
                                </span>
                                <input asp-for="FullName" class="create-form-input" 
                                       placeholder="e.g. Ahmed Khan" />
                            </div>
                            <span asp-validation-for="FullName" class="create-form-error"></span>
                        </div>

                        <!-- Mobile Number -->
                        <div class="create-form-group">
                            <label class="create-form-label">
                                <span>Mobile Number</span>
                                <span class="create-form-label__required">*</span>
                            </label>
                            <div class="create-input-wrapper">
                                <span class="create-input-icon">
                                    <i class="las la-phone-alt"></i>
                                </span>
                                <input asp-for="MobileNumber" class="create-form-input" 
                                       maxlength="10" placeholder="10-digit mobile number" />
                            </div>
                            <span asp-validation-for="MobileNumber" class="create-form-error"></span>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="create-form-grid__col">
                        <!-- Email -->
                        <div class="create-form-group">
                            <label class="create-form-label">
                                <span>Email Address</span>
                                <span class="create-form-label__optional">optional</span>
                            </label>
                            <div class="create-input-wrapper">
                                <span class="create-input-icon">
                                    <i class="las la-envelope"></i>
                                </span>
                                <input asp-for="Email" class="create-form-input" 
                                       placeholder="user@example.com" />
                            </div>
                        </div>

                        <!-- Password -->
                        <div class="create-form-group">
                            <label class="create-form-label">
                                <span>Password</span>
                                <span class="create-form-label__required">*</span>
                            </label>
                            <div class="create-input-wrapper">
                                <span class="create-input-icon">
                                    <i class="las la-lock"></i>
                                </span>
                                <input asp-for="Password" type="password" class="create-form-input" 
                                       placeholder="Minimum 6 characters" />
                            </div>
                            <span asp-validation-for="Password" class="create-form-error"></span>
                        </div>
                    </div>
                </div>

                <!-- Plan Type Selection - Full Width -->
                <div class="create-form-group create-form-group--full">
                    <label class="create-form-label">
                        <span>Plan Type</span>
                        <span class="create-form-label__required">*</span>
                    </label>
                    
                    <div class="create-plan-grid">
                        <!-- Prepaid Option -->
                        <label class="create-plan-option">
                            <input type="radio" asp-for="PlanType" value="Prepaid" checked class="create-plan-option__radio">
                            <div class="create-plan-option__card">
                                <div class="create-plan-option__icon prepaid-icon">
                                    <i class="las la-sim-card"></i>
                                </div>
                                <div class="create-plan-option__content">
                                    <span class="create-plan-option__title">Prepaid</span>
                                    <span class="create-plan-option__desc">Pay before you use</span>
                                </div>
                                <div class="create-plan-option__check">
                                    <i class="las la-check-circle"></i>
                                </div>
                            </div>
                        </label>

                        <!-- Postpaid Option -->
                        <label class="create-plan-option">
                            <input type="radio" asp-for="PlanType" value="Postpaid" class="create-plan-option__radio">
                            <div class="create-plan-option__card">
                                <div class="create-plan-option__icon postpaid-icon">
                                    <i class="las la-calendar-check"></i>
                                </div>
                                <div class="create-plan-option__content">
                                    <span class="create-plan-option__title">Postpaid</span>
                                    <span class="create-plan-option__desc">Pay monthly bill</span>
                                </div>
                                <div class="create-plan-option__check">
                                    <i class="las la-check-circle"></i>
                                </div>
                            </div>
                        </label>
                    </div>
                    <span asp-validation-for="PlanType" class="create-form-error"></span>
                </div>

                <!-- Form Actions -->
                <div class="create-form-actions">
                    <button type="submit" class="btn btn-primary btn-large">
                        <i class="las la-user-plus"></i>
                        <span>Create User</span>
                    </button>
                    <a href="/Admin/Users" class="btn btn-secondary btn-large">
                        <i class="las la-times"></i>
                        <span>Cancel</span>
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Password Strength Indicator (Optional Enhancement) -->
<div class="password-strength" style="display: none;">
    <div class="strength-meter">
        <div class="strength-meter-fill"></div>
    </div>
    <span class="strength-text"></span>
</div>

<style>
    /* =======================================================
       MODERN CREATE USER PAGE - Premium Design System
       Colors preserved from :root variables
    ======================================================= */

    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

    /* Global Reset */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', sans-serif;
        background: hsl(var(--section-bg));
        color: hsl(var(--text-color));
        line-height: 1.5;
    }

    /* ==================== ALERTS ==================== */
    .alert-modern {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.5rem;
        border-radius: 16px;
        margin-bottom: 2rem;
        font-weight: 500;
        animation: slideInDown 0.3s ease;
        border-left: 4px solid transparent;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }

    .alert-success {
        background: linear-gradient(135deg, hsl(180 70% 38% / 0.1), hsl(200 85% 48% / 0.1));
        border-left-color: hsl(180 70% 38%);
        color: hsl(180 70% 30%);
    }

    .alert-error {
        background: linear-gradient(135deg, hsl(0 85% 55% / 0.1), hsl(0 85% 45% / 0.1));
        border-left-color: hsl(0 85% 55%);
        color: hsl(0 85% 35%);
    }

    .alert-modern i {
        font-size: 1.5rem;
    }

    @@keyframes slideInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ==================== PAGE HEADER ==================== */
    .create-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin-bottom: 2rem;
        animation: fadeIn 0.5s ease;
    }

    .create-page-header__left {
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }

    .create-page-header__icon {
        width: 64px;
        height: 64px;
        border-radius: 20px;
        background: linear-gradient(135deg, 
            hsl(180 70% 38%), 
            hsl(200 85% 48%));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 2rem;
        box-shadow: 0 15px 30px -10px hsl(180 70% 38% / 0.4);
    }

    .create-page-header__title {
        font-size: 2rem;
        font-weight: 700;
        color: hsl(var(--heading-color));
        margin: 0;
        line-height: 1.2;
    }

    .create-page-header__subtitle {
        font-size: 0.95rem;
        color: hsl(var(--text-color) / 0.7);
        margin: 0.25rem 0 0;
    }

    /* ==================== BUTTONS ==================== */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1.5rem;
        border-radius: 40px;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.2, 0.9, 0.4, 1);
        cursor: pointer;
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .btn-outline {
        background: transparent;
        border: 1px solid hsl(var(--border-color));
        color: hsl(var(--text-color));
    }

    .btn-outline:hover {
        background: hsl(var(--base) / 0.05);
        border-color: hsl(var(--base));
        color: hsl(var(--base));
        transform: translateY(-2px);
    }

    .btn-primary {
        background: linear-gradient(135deg, 
            hsl(var(--base)), 
            hsl(var(--base-two)));
        color: white;
        box-shadow: 0 10px 20px -8px hsl(var(--base) / 0.5);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 30px -8px hsl(var(--base) / 0.6);
    }

    .btn-secondary {
        background: hsl(var(--section-bg));
        border: 1px solid hsl(var(--border-color));
        color: hsl(var(--text-color));
    }

    .btn-secondary:hover {
        background: hsl(var(--border-color) / 0.3);
        transform: translateY(-2px);
    }

    .btn-large {
        padding: 0.875rem 2rem;
        font-size: 1rem;
    }

    .btn i {
        font-size: 1.2rem;
    }

    /* ==================== FORM CONTAINER ==================== */
    .create-form-container {
        animation: fadeInUp 0.5s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .create-form-card {
        background: white;
        border-radius: 28px;
        border: 1px solid hsl(var(--border-color) / 0.4);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
        overflow: hidden;
    }

    /* Card Header */
    .create-form-card__header {
        padding: 1.5rem 2rem;
        background: linear-gradient(135deg, 
            hsl(var(--section-bg) / 0.8), 
            white);
        border-bottom: 1px solid hsl(var(--border-color) / 0.3);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .create-form-card__header-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .create-form-card__dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: linear-gradient(135deg, 
            hsl(180 70% 38%), 
            hsl(200 85% 48%));
        box-shadow: 0 0 0 3px hsl(180 70% 38% / 0.2);
    }

    .create-form-card__title {
        font-size: 1.25rem;
        font-weight: 700;
        color: hsl(var(--heading-color));
        margin: 0;
    }

    .create-form-card__badge {
        padding: 0.35rem 1.25rem;
        background: hsl(180 70% 38% / 0.1);
        color: hsl(180 70% 38%);
        border-radius: 40px;
        font-size: 0.8rem;
        font-weight: 600;
        border: 1px solid hsl(180 70% 38% / 0.2);
    }

    /* Card Body */
    .create-form-card__body {
        padding: 2rem;
    }

    /* Validation Summary */
    .form-validation-summary {
        background: hsl(0 85% 55% / 0.1);
        border-left: 4px solid hsl(0 85% 55%);
        border-radius: 12px;
        padding: 1rem 1.5rem;
        margin-bottom: 2rem;
        color: hsl(0 85% 35%);
        font-size: 0.9rem;
    }

    .form-validation-summary ul {
        margin: 0.5rem 0 0 1.5rem;
    }

    /* ==================== FORM GRID ==================== */
    .create-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 768px) {
        .create-form-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }
    }

    /* ==================== FORM GROUPS ==================== */
    .create-form-group {
        margin-bottom: 1.5rem;
    }

    .create-form-group--full {
        grid-column: 1 / -1;
        margin-bottom: 2rem;
    }

    .create-form-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
        font-weight: 600;
        font-size: 0.95rem;
        color: hsl(var(--heading-color));
    }

    .create-form-label__required {
        color: hsl(0 85% 55%);
        font-size: 1.2rem;
        line-height: 1;
    }

    .create-form-label__optional {
        color: hsl(var(--text-color) / 0.5);
        font-size: 0.8rem;
        font-weight: 400;
        margin-left: 0.5rem;
    }

    /* Input Wrapper */
    .create-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .create-input-icon {
        position: absolute;
        left: 1rem;
        color: hsl(180 70% 38%);
        font-size: 1.2rem;
        opacity: 0.7;
        transition: all 0.2s ease;
    }

    .create-form-input {
        width: 100%;
        padding: 0.875rem 1rem 0.875rem 3rem;
        border: 2px solid hsl(var(--border-color) / 0.5);
        border-radius: 16px;
        font-size: 0.95rem;
        font-family: inherit;
        transition: all 0.2s ease;
        background: white;
        color: hsl(var(--heading-color));
    }

    .create-form-input:focus {
        outline: none;
        border-color: hsl(180 70% 38%);
        box-shadow: 0 0 0 4px hsl(180 70% 38% / 0.1);
    }

    .create-form-input:hover {
        border-color: hsl(180 70% 38% / 0.5);
    }

    .create-form-input::placeholder {
        color: hsl(var(--text-color) / 0.4);
    }

    /* Error Message */
    .create-form-error {
        display: block;
        margin-top: 0.5rem;
        font-size: 0.8rem;
        color: hsl(0 85% 55%);
        padding-left: 0.5rem;
    }

    /* ==================== PLAN SELECTION ==================== */
    .create-plan-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin: 0.5rem 0;
    }

    .create-plan-option {
        cursor: pointer;
        display: block;
    }

    .create-plan-option__radio {
        display: none;
    }

    .create-plan-option__card {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.5rem;
        background: white;
        border: 2px solid hsl(var(--border-color) / 0.5);
        border-radius: 24px;
        transition: all 0.3s cubic-bezier(0.2, 0.9, 0.4, 1);
        position: relative;
    }

    .create-plan-option__radio:checked + .create-plan-option__card {
        border-color: hsl(180 70% 38%);
        background: linear-gradient(135deg, 
            hsl(180 70% 38% / 0.02), 
            hsl(200 85% 48% / 0.02));
        box-shadow: 0 15px 30px -12px hsl(180 70% 38% / 0.3);
        transform: translateY(-2px);
    }

    .create-plan-option__card:hover {
        border-color: hsl(180 70% 38% / 0.5);
        transform: translateY(-2px);
        box-shadow: 0 15px 30px -12px rgba(0, 0, 0, 0.1);
    }

    .create-plan-option__icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        transition: all 0.3s ease;
    }

    .prepaid-icon {
        background: hsl(180 70% 38% / 0.1);
        color: hsl(180 70% 38%);
    }

    .postpaid-icon {
        background: hsl(200 85% 48% / 0.1);
        color: hsl(200 85% 48%);
    }

    .create-plan-option__content {
        flex: 1;
    }

    .create-plan-option__title {
        display: block;
        font-weight: 700;
        font-size: 1.1rem;
        color: hsl(var(--heading-color));
        margin-bottom: 0.25rem;
    }

    .create-plan-option__desc {
        display: block;
        font-size: 0.8rem;
        color: hsl(var(--text-color) / 0.7);
    }

    .create-plan-option__check {
        color: hsl(180 70% 38%);
        font-size: 1.5rem;
        opacity: 0;
        transform: scale(0.5);
        transition: all 0.3s cubic-bezier(0.2, 0.9, 0.4, 1);
    }

    .create-plan-option__radio:checked + .create-plan-option__card .create-plan-option__check {
        opacity: 1;
        transform: scale(1);
    }

    /* ==================== FORM ACTIONS ==================== */
    .create-form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid hsl(var(--border-color) / 0.3);
    }

    @@media (max-width: 480px) {
        .create-form-actions {
            flex-direction: column;
        }
        
        .create-form-actions .btn {
            width: 100%;
            justify-content: center;
        }
    }

    /* ==================== PASSWORD STRENGTH INDICATOR ==================== */
    .password-strength {
        margin-top: 0.5rem;
    }

    .strength-meter {
        height: 4px;
        background: hsl(var(--border-color));
        border-radius: 4px;
        overflow: hidden;
        margin-bottom: 0.25rem;
    }

    .strength-meter-fill {
        height: 100%;
        width: 0;
        border-radius: 4px;
        transition: width 0.3s ease, background-color 0.3s ease;
    }

    .strength-text {
        font-size: 0.75rem;
        color: hsl(var(--text-color) / 0.6);
    }

    /* ==================== RESPONSIVE ADJUSTMENTS ==================== */
    @@media (max-width: 1024px) {
        .create-page-header__title {
            font-size: 1.75rem;
        }
        
        .create-form-card__header {
            padding: 1.25rem 1.5rem;
        }
        
        .create-form-card__body {
            padding: 1.5rem;
        }
    }

    @@media (max-width: 768px) {
        .create-page-header {
            flex-direction: column;
            align-items: flex-start;
        }
        
        .create-page-header__left {
            width: 100%;
        }
        
        .create-page-header__right {
            width: 100%;
        }
        
        .create-page-header__right .btn {
            width: 100%;
            justify-content: center;
        }
        
        .create-plan-grid {
            grid-template-columns: 1fr;
        }
        
        .create-form-card__badge {
            display: none;
        }
    }

    @@media (max-width: 480px) {
        .create-page-header__icon {
            width: 48px;
            height: 48px;
            font-size: 1.5rem;
        }
        
        .create-page-header__title {
            font-size: 1.5rem;
        }
        
        .create-form-card__header {
            flex-direction: column;
            align-items: flex-start;
        }
        
        .create-plan-option__card {
            padding: 1rem;
        }
        
        .create-plan-option__icon {
            width: 48px;
            height: 48px;
            font-size: 1.5rem;
        }
        
        .create-plan-option__title {
            font-size: 1rem;
        }
    }

    /* ==================== ANIMATIONS ==================== */
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    /* Input focus animation */
    .create-form-input:focus + .create-input-icon {
        color: hsl(200 85% 48%);
        transform: scale(1.1);
    }

    /* Validation styling */
    .input-validation-error {
        border-color: hsl(0 85% 55%) !important;
    }

    .field-validation-error {
        color: hsl(0 85% 55%);
        font-size: 0.8rem;
        margin-top: 0.25rem;
        display: block;
    }
</style>

<!-- Optional: Password Strength Script -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Add active state to selected plan
        const radios = document.querySelectorAll('.create-plan-option__radio');
        radios.forEach(radio => {
            if (radio.checked) {
                radio.closest('.create-plan-option').classList.add('selected');
            }
            
            radio.addEventListener('change', function() {
                document.querySelectorAll('.create-plan-option').forEach(opt => {
                    opt.classList.remove('selected');
                });
                if (this.checked) {
                    this.closest('.create-plan-option').classList.add('selected');
                }
            });
        });

        // Optional: Password strength checker
        const passwordInput = document.querySelector('input[type="password"]');
        if (passwordInput) {
            passwordInput.addEventListener('input', function() {
                // You can implement password strength logic here
                console.log('Password length:', this.value.length);
            });
        }
    });
</script>

@await Html.PartialAsync("_LevelUpStyles")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}