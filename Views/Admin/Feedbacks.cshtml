@model IEnumerable<MobileRechargeApp.Models.Feedback>
@{
    ViewData["Title"] = "Feedbacks";
    Layout = "_AdminLayout";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mb-4" style="border-radius: 1rem; padding: 1rem 1.5rem; border-left: 4px solid hsl(var(--base));">
        <i class="las la-check-circle" style="color: hsl(var(--base));"></i>
        @TempData["Success"]
    </div>
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1" style="font-family: 'ClashDisplay-Variable', sans-serif;">
            <i class="las la-comments" style="color: hsl(var(--base));"></i>
            User Feedbacks
        </h2>
        <p class="text-muted mb-0">View all customer feedback and reviews</p>
    </div>
    <span class="happy-users-badge" style="padding: 0.5rem 1.5rem;">
        <i class="las la-comment"></i>
        <span>@Model.Count() Total</span>
    </span>
</div>

<!-- Feedbacks Grid -->
<div class="row g-4">
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="transactions-panel p-5 text-center">
                <i class="las la-comments" style="font-size: 4rem; color: hsl(var(--text-color) / 0.2);"></i>
                <h4 class="mt-3 mb-2">No Feedbacks Yet</h4>
                <p class="text-muted mb-0">Customer feedback will appear here</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var f in Model)
        {
            <div class="col-lg-6">
                <div class="quick-stat-card" style="flex-direction: column; align-items: flex-start;">
                    <div class="d-flex justify-content-between w-100 mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <div class="quick-icon" style="width: 2.5rem; height: 2.5rem;">
                                <i class="las la-user"></i>
                            </div>
                            <div>
                                <h6 class="mb-0">@f.Name</h6>
                                <small class="text-muted">@f.Email</small>
                            </div>
                        </div>
                        <span class="badge-custom" style="background: hsl(var(--base) / 0.1); color: hsl(var(--base));">
                            #@f.FeedbackId
                        </span>
                    </div>
                    
                    <p class="mb-3" style="color: hsl(var(--text-color)); line-height: 1.6;">
                        "@f.Message"
                    </p>
                    
                    <div class="d-flex align-items-center justify-content-between mt-3">
                        <div class="d-flex align-items-center gap-2">
                            <i class="las la-clock" style="color: hsl(var(--text-color) / 0.5);"></i>
                            <small class="text-muted">@f.SubmittedAt.ToString("dd MMM yyyy, hh:mm tt")</small>
                        </div>
                        <form method="post" action="/Admin/DeleteFeedback" style="margin:0;"
                              onsubmit="return confirm('Delete this feedback from @f.Name?');">
                            <input type="hidden" name="id" value="@f.FeedbackId" />
                            <button type="submit" class="btn-delete-fb">
                                <i class="las la-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>
<style>
    .btn-delete-fb { background:hsl(0 100% 50%/0.1);color:hsl(0 100% 45%);border:1px solid hsl(0 100% 50%/0.3);padding:5px 12px;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:5px;transition:0.2s; }
    .btn-delete-fb:hover { background:hsl(0 100% 50%);color:#fff; }
</style>