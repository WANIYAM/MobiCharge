@model MobileRechargeApp.Models.SpecialPlan
@{
    ViewData["Title"] = "Edit Special Plan";
    Layout = "_AdminLayout";
}

<!-- Page Header -->
<div class="edit-header">
    <div class="edit-header-left">
        <div class="edit-header-icon" style="background: linear-gradient(135deg, hsl(var(--base-two)), hsl(var(--base)));">
            <i class="las la-edit"></i>
        </div>
        <div>
            <h1 class="edit-header-title">Edit Special Plan</h1>
            <p class="edit-header-subtitle">Update plan #@Model.PlanId details</p>
        </div>
    </div>
    <a href="/Admin/SpecialPlans" class="btn-back">
        <i class="las la-arrow-left"></i>
        <span>Back to Plans</span>
    </a>
</div>

<!-- Edit Form Card -->
<div class="edit-card">
    <div class="edit-card-header">
        <div class="edit-card-header-left">
            <span class="edit-card-dot" style="background: hsl(var(--base-two));"></span>
            <h3 class="edit-card-title">Plan Information</h3>
        </div>
        <span class="edit-card-badge" style="background: hsl(var(--base-two) / 0.1); color: hsl(var(--base-two));">Edit Mode</span>
    </div>
    
    <div class="edit-card-body">
        <form asp-action="EditSpecialPlan" method="post">
            <input type="hidden" asp-for="PlanId" />

            <div class="form-grid">
                <!-- Left Column -->
                <div class="form-group">
                    <label class="form-label">
                        <span>Amount (Rs.)</span>
                        <span class="required-star">*</span>
                    </label>
                    <div class="input-wrapper">
                        <span class="input-icon" style="color: hsl(var(--base-two));">
                            <i class="las la-money-bill"></i>
                        </span>
                        <input asp-for="Amount" class="form-input" placeholder="Enter amount" />
                    </div>
                    <span asp-validation-for="Amount" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <span>Validity (Days)</span>
                        <span class="required-star">*</span>
                    </label>
                    <div class="input-wrapper">
                        <span class="input-icon" style="color: hsl(var(--base-two));">
                            <i class="las la-calendar"></i>
                        </span>
                        <input asp-for="Validity" class="form-input" placeholder="Enter validity in days" />
                    </div>
                    <span asp-validation-for="Validity" class="validation-error"></span>
                </div>

                <!-- Full Width Fields -->
                <div class="form-group full-width">
                    <label class="form-label">
                        <span>Description</span>
                        <span class="required-star">*</span>
                    </label>
                    <div class="input-wrapper">
                        <span class="input-icon" style="color: hsl(var(--base-two));">
                            <i class="las la-align-left"></i>
                        </span>
                        <input asp-for="Description" class="form-input" placeholder="Enter plan description" />
                    </div>
                    <span asp-validation-for="Description" class="validation-error"></span>
                </div>

                <div class="form-group full-width">
                    <label class="form-label">
                        <span>Benefits</span>
                        <span class="required-star">*</span>
                    </label>
                    <div class="input-wrapper">
                        <span class="input-icon" style="color: hsl(var(--base-two));">
                            <i class="las la-gift"></i>
                        </span>
                        <input asp-for="Benefits" class="form-input" placeholder="Enter plan benefits" />
                    </div>
                    <span asp-validation-for="Benefits" class="validation-error"></span>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <button type="submit" class="btn-submit" style="background: linear-gradient(135deg, hsl(var(--base-two)), hsl(var(--base)));">
                    <i class="las la-save"></i>
                    <span>Update Plan</span>
                </button>
                <a href="/Admin/SpecialPlans" class="btn-cancel" style="border-color: hsl(var(--border-color)); color: hsl(var(--text-color));">
                    <i class="las la-times"></i>
                    <span>Cancel</span>
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    /* ===== EDIT PAGE STYLES - Special Plan ===== */
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', sans-serif;
        background: hsl(var(--section-bg));
        color: hsl(var(--text-color));
    }

    /* Page Header */
    .edit-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .edit-header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .edit-header-icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 26px;
        box-shadow: 0 8px 20px -4px hsl(var(--base-two) / 0.4);
    }

    .edit-header-title {
        font-size: 24px;
        font-weight: 700;
        color: hsl(var(--heading-color));
        margin: 0 0 4px;
    }

    .edit-header-subtitle {
        font-size: 14px;
        color: hsl(var(--text-color) / 0.7);
        margin: 0;
    }

    .btn-back {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: transparent;
        border: 1px solid hsl(var(--border-color));
        border-radius: 40px;
        color: hsl(var(--text-color));
        font-weight: 500;
        font-size: 14px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .btn-back:hover {
            border-color: hsl(var(--base-two));
            color: hsl(var(--base-two));
            transform: translateX(-5px);
        }

    /* Edit Card */
    .edit-card {
        background: white;
        border-radius: 28px;
        border: 1px solid hsl(var(--border-color) / 0.4);
        box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        max-width: 800px;
        margin: 0 auto;
    }

    .edit-card-header {
        padding: 20px 24px;
        background: linear-gradient(135deg, hsl(var(--section-bg) / 0.8), white);
        border-bottom: 1px solid hsl(var(--border-color) / 0.3);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

    .edit-card-header-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .edit-card-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        box-shadow: 0 0 0 3px hsl(var(--base-two) / 0.2);
    }

    .edit-card-title {
        font-size: 18px;
        font-weight: 700;
        color: hsl(var(--heading-color));
        margin: 0;
    }

    .edit-card-badge {
        padding: 6px 16px;
        border-radius: 40px;
        font-size: 13px;
        font-weight: 600;
        border: 1px solid hsl(var(--base-two) / 0.2);
    }

    .edit-card-body {
        padding: 30px;
    }

    /* Form Grid */
    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
        margin-bottom: 30px;
    }

    .form-group {
        margin-bottom: 0;
    }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

    .form-label {
        display: flex;
        align-items: center;
        gap: 4px;
        margin-bottom: 8px;
        font-weight: 600;
        font-size: 14px;
        color: hsl(var(--heading-color));
    }

    .required-star {
        color: #dc2626;
        font-size: 16px;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon {
        position: absolute;
        left: 14px;
        font-size: 18px;
        opacity: 0.7;
    }

    .form-input {
        width: 100%;
        padding: 14px 14px 14px 45px;
        border: 2px solid hsl(var(--border-color) / 0.5);
        border-radius: 16px;
        font-size: 15px;
        font-family: inherit;
        transition: all 0.3s ease;
        background: white;
        color: hsl(var(--heading-color));
    }

        .form-input:focus {
            outline: none;
            border-color: hsl(var(--base-two));
            box-shadow: 0 0 0 4px hsl(var(--base-two) / 0.1);
        }

        .form-input::placeholder {
            color: hsl(var(--text-color) / 0.4);
        }

    .validation-error {
        display: block;
        margin-top: 6px;
        font-size: 12px;
        color: #dc2626;
        padding-left: 4px;
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 16px;
        padding-top: 20px;
        border-top: 1px solid hsl(var(--border-color) / 0.3);
    }

    .btn-submit, .btn-cancel {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 32px;
        border-radius: 40px;
        font-weight: 600;
        font-size: 15px;
        text-decoration: none;
        transition: all 0.3s ease;
        border: 1px solid transparent;
        cursor: pointer;
        font-family: inherit;
    }

    .btn-submit {
        color: white;
        flex: 2;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px hsl(var(--base-two) / 0.4);
        }

    .btn-cancel {
        background: transparent;
        border: 1px solid;
        flex: 1;
    }

        .btn-cancel:hover {
            background: hsl(var(--section-bg));
            transform: translateY(-2px);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .edit-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .edit-header-icon {
            width: 48px;
            height: 48px;
            font-size: 22px;
        }

        .edit-header-title {
            font-size: 22px;
        }

        .edit-card-body {
            padding: 20px;
        }

        .form-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn-submit, .btn-cancel {
            width: 100%;
        }
    }

    @@media (max-width: 480px) {
        .edit-card-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .edit-card-badge {
            align-self: flex-start;
        }

        .form-input {
            padding: 12px 12px 12px 40px;
            font-size: 14px;
        }
    }
</style>