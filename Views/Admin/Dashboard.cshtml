@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

@{
    int topUp   = ViewBag.TotalTopUpPlans   ?? 0;
    int special = ViewBag.TotalSpecialPlans ?? 0;
    int total   = topUp + special;

    double circ       = 2 * Math.PI * 46;          // r=46
    double topUpArc   = total > 0 ? topUp   * circ / total : circ * 0.5;
    double specialArc = total > 0 ? special * circ / total : circ * 0.5;
}

<!-- ══════════════════ BENTO DASHBOARD ══════════════════ -->
<div class="bento">

    <!-- ① HERO REVENUE (spans 2 cols) -->
    <div class="bento__cell bento__hero">
        <div class="hero-orb hero-orb--a"></div>
        <div class="hero-orb hero-orb--b"></div>
        <div class="hero-orb hero-orb--c"></div>
        <div class="hero-body">
            <div class="hero-label">
                <span class="hero-pulse"></span> Total Revenue
            </div>
            <div class="hero-amount">Rs. @ViewBag.TotalRevenue</div>
            <div class="hero-sub">All-time platform earnings</div>
        </div>
        <div class="hero-icon-wrap">
            <i class="las la-chart-line"></i>
        </div>
    </div>

    <!-- ② USERS -->
    <div class="bento__cell bento__stat" style="--c:var(--base);">
        <div class="st-row">
            <div class="st-icon"><i class="las la-users"></i></div>
            <span class="st-badge st-badge--base">Active</span>
        </div>
        <div class="st-num">@ViewBag.TotalUsers</div>
        <div class="st-lbl">Registered Users</div>
        <a href="/Admin/Users" class="st-link">Manage users <i class="las la-long-arrow-alt-right"></i></a>
    </div>

    <!-- ③ TRANSACTIONS -->
    <div class="bento__cell bento__stat" style="--c:var(--base-two);">
        <div class="st-row">
            <div class="st-icon" style="background:hsl(var(--base-two)/.12);color:hsl(var(--base-two));">
                <i class="las la-exchange-alt"></i>
            </div>
            <span class="st-badge" style="background:hsl(var(--base-two)/.12);color:hsl(var(--base-two));">Total</span>
        </div>
        <div class="st-num">@ViewBag.TotalTransactions</div>
        <div class="st-lbl">Transactions</div>
        <a href="/Admin/Transactions" class="st-link" style="color:hsl(var(--base-two));">
            View all <i class="las la-long-arrow-alt-right"></i>
        </a>
    </div>

    <!-- ④ FEEDBACKS -->
    <div class="bento__cell bento__stat" style="--c:38 95% 48%;">
        <div class="st-row">
            <div class="st-icon" style="background:hsl(38 95% 48%/.12);color:hsl(38 95% 38%);">
                <i class="las la-comments"></i>
            </div>
        </div>
        <div class="st-num">@ViewBag.TotalFeedbacks</div>
        <div class="st-lbl">User Feedbacks</div>
        <a href="/Admin/Feedbacks" class="st-link" style="color:hsl(38 95% 38%);">
            View all <i class="las la-long-arrow-alt-right"></i>
        </a>
    </div>

    <!-- ⑤ RECENT TRANSACTIONS (wide) -->
    <div class="bento__cell bento__txns">
        <div class="c-hdr">
            <div class="c-hdr__l">
                <span class="c-hdr__dot"></span>
                <span class="c-hdr__title">Recent Transactions</span>
            </div>
            <a href="/Admin/Transactions" class="c-hdr__link">
                View all <i class="las la-arrow-right"></i>
            </a>
        </div>
        <div class="txn-feed">
            @if (ViewBag.RecentTransactions == null || ((IEnumerable<dynamic>)ViewBag.RecentTransactions).Count() == 0)
            {
                <div class="empty-state" style="padding:3rem;">
                    <i class="las la-inbox"></i><p>No transactions yet</p>
                </div>
            }
            else
            {
                int idx = 0;
                @foreach (var t in ViewBag.RecentTransactions)
                {
                    string icon  = t.PlanType == "topup"   ? "la-sim-card" :
                                   t.PlanType == "special" ? "la-star"     : "la-calendar";
                    string clr   = t.PlanType == "topup"   ? "var(--base)" :
                                   t.PlanType == "special" ? "var(--base-two)" : "38 95% 40%";
                    string label = t.PlanType == "topup"   ? "Top Up Recharge" :
                                   t.PlanType == "special" ? "Special Plan" : "Postpaid Bill";
                    idx++;

                    <div class="txn-row" style="animation-delay:@(idx * 0.06)s">
                        <div class="txn-ico" style="color:hsl(@clr);background:hsl(@clr/.1);">
                            <i class="las @icon"></i>
                        </div>
                        <div class="txn-info">
                            <div class="txn-name">@label</div>
                            <div class="txn-meta">
                                <i class="las la-phone-alt"></i> @t.MobileNumber
                                &nbsp;·&nbsp;
                                <i class="las la-clock"></i> @t.TxnDate.ToString("dd MMM · hh:mm tt")
                            </div>
                        </div>
                        <div class="txn-amt">+ Rs. @t.Amount</div>
                        <div class="txn-ok"><i class="las la-check-circle"></i></div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- ⑥ DONUT CHART -->
    <div class="bento__cell bento__donut">
        <div class="c-hdr">
            <div class="c-hdr__l">
                <span class="c-hdr__dot" style="background:hsl(var(--base-two));"></span>
                <span class="c-hdr__title">Plan Mix</span>
            </div>
        </div>
        <div class="donut-wrap">
            <svg viewBox="0 0 120 120" class="donut-svg">
                <circle cx="60" cy="60" r="46" fill="none"
                        stroke="hsl(var(--border-color))" stroke-width="11"/>
                <circle cx="60" cy="60" r="46" fill="none"
                        stroke="hsl(var(--base))" stroke-width="11"
                        stroke-linecap="round"
                        stroke-dasharray="@topUpArc.ToString("F1") @circ.ToString("F1")"
                        transform="rotate(-90 60 60)"
                        class="d-arc"/>
                <circle cx="60" cy="60" r="46" fill="none"
                        stroke="hsl(var(--base-two))" stroke-width="11"
                        stroke-linecap="round"
                        stroke-dasharray="@specialArc.ToString("F1") @circ.ToString("F1")"
                        stroke-dashoffset="-@topUpArc.ToString("F1")"
                        transform="rotate(-90 60 60)"
                        class="d-arc d-arc--b"/>
                <text x="60" y="56" text-anchor="middle"
                      font-size="17" font-weight="800"
                      fill="hsl(var(--heading-color))"
                      font-family="'ClashDisplay-Variable',sans-serif">@total</text>
                <text x="60" y="70" text-anchor="middle"
                      font-size="7.5" fill="hsl(var(--text-color))"
                      font-family="sans-serif">Plans</text>
            </svg>
        </div>
        <div class="donut-legs">
            <div class="d-leg">
                <span class="d-dot" style="background:hsl(var(--base));"></span>
                <span>Top Up</span>
                <strong>@topUp</strong>
            </div>
            <div class="d-leg">
                <span class="d-dot" style="background:hsl(var(--base-two));"></span>
                <span>Special</span>
                <strong>@special</strong>
            </div>
        </div>
    </div>

    <!-- ⑦ QUICK ACTIONS -->
    <div class="bento__cell bento__actions">
        <div class="c-hdr">
            <div class="c-hdr__l">
                <span class="c-hdr__dot" style="background:hsl(38 95% 55%);"></span>
                <span class="c-hdr__title">Quick Actions</span>
            </div>
        </div>
        <div class="qa-grid">
            <a href="/Admin/CreateUser"     class="qa-tile">
                <i class="las la-user-plus"></i><span>Add User</span>
            </a>
            <a href="/Admin/AddTopUpPlan"   class="qa-tile">
                <i class="las la-mobile"></i><span>Top Up Plan</span>
            </a>
            <a href="/Admin/AddSpecialPlan" class="qa-tile">
                <i class="las la-star"></i><span>Special Plan</span>
            </a>
            <a href="/" target="_blank"     class="qa-tile qa-glow">
                <i class="las la-external-link-alt"></i><span>View Site</span>
            </a>
        </div>
    </div>

</div>

<style>
/* ════════════════════════════════════════════
   BENTO GRID  —  4 cols
════════════════════════════════════════════ */
.bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.1rem;
    animation: fadeUp .4s ease both;
}
@@keyframes fadeUp {
    from { opacity:0; transform:translateY(18px); }
    to   { opacity:1; transform:translateY(0); }
}

/* base cell */
.bento__cell {
    background: hsl(var(--white));
    border-radius: 1.4rem;
    border: 1px solid hsl(var(--border-color));
    box-shadow: 0 2px 14px hsl(0 0% 0%/.04);
    overflow: hidden;
    position: relative;
    transition: transform .25s, box-shadow .25s;
}
.bento__cell:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px hsl(0 0% 0%/.09);
}

/* ── ① Hero ── */
.bento__hero {
    grid-column: 1 / 3;
    grid-row: 1;
    background: linear-gradient(135deg,
        hsl(var(--base)) 0%,
        hsl(var(--base-two)) 100%);
    border-color: transparent;
    box-shadow: 0 12px 40px hsl(var(--base)/.28);
    padding: 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    min-height: 155px;
}
.bento__hero:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 48px hsl(var(--base)/.36);
}

.hero-orb {
    position:absolute; border-radius:50%; pointer-events:none;
}
.hero-orb--a { width:180px;height:180px;background:rgba(255,255,255,.08);top:-55px;right:120px; }
.hero-orb--b { width:100px;height:100px;background:rgba(255,255,255,.06);bottom:-30px;right:40px; }
.hero-orb--c { width:60px; height:60px; background:rgba(0,0,0,.07);     top:25px;  left:52%; }

.hero-body { position:relative; z-index:1; }

.hero-label {
    display: flex; align-items: center; gap:.45rem;
    font-size:.78rem; font-weight:700;
    color:rgba(255,255,255,.85);
    text-transform: uppercase; letter-spacing:.06em;
    margin-bottom:.55rem;
}
.hero-pulse {
    width:7px; height:7px; border-radius:50%; background:#fff; flex-shrink:0;
    animation: hbeat 2s infinite;
}
@@keyframes hbeat {
    0%,100%{opacity:1;transform:scale(1);}
    50%{opacity:.4;transform:scale(.65);}
}
.hero-amount {
    font-size: 2.8rem; font-weight:900; color:#fff;
    line-height:1; letter-spacing:-.03em;
    font-family: 'ClashDisplay-Variable', sans-serif;
    margin-bottom:.3rem;
}
.hero-sub { font-size:.78rem; color:rgba(255,255,255,.65); }

.hero-icon-wrap {
    position:relative; z-index:1; align-self:flex-start;
    width:3.4rem; height:3.4rem; border-radius:.9rem;
    background:rgba(255,255,255,.15); backdrop-filter:blur(8px);
    display:flex; align-items:center; justify-content:center;
    font-size:1.6rem; color:#fff;
}

/* ── ② ③ ④ Stats ── */
.bento__stat {
    padding: 1.35rem 1.5rem 1.25rem;
    display: flex; flex-direction:column; gap:.3rem;
}
.bento__stat:nth-of-type(2) { grid-column:3; grid-row:1; }
.bento__stat:nth-of-type(3) { grid-column:4; grid-row:1; }
.bento__stat:nth-of-type(4) { grid-column:4; grid-row:2; }

/* top accent bar */
.bento__stat::before {
    content:'';
    position:absolute; top:0; left:0; right:0; height:3px;
    background: linear-gradient(90deg, hsl(var(--c,var(--base))), hsl(var(--base-two)));
    border-radius:1.4rem 1.4rem 0 0;
}

.st-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:.55rem; }
.st-icon {
    width:2.6rem; height:2.6rem; border-radius:.8rem;
    background:hsl(var(--base)/.1); color:hsl(var(--base));
    display:flex; align-items:center; justify-content:center;
    font-size:1.3rem;
}
.st-badge {
    font-size:.68rem; font-weight:700; padding:3px 9px;
    border-radius:20px; letter-spacing:.03em;
}
.st-badge--base { background:hsl(var(--base)/.12); color:hsl(var(--base)); }

.st-num {
    font-size:2.1rem; font-weight:900;
    color:hsl(var(--heading-color));
    line-height:1; letter-spacing:-.025em;
    font-family:'ClashDisplay-Variable',sans-serif;
    margin-top:.15rem;
}
.st-lbl { font-size:.79rem; color:hsl(var(--text-color)/.6); font-weight:500; }
.st-link {
    margin-top: auto; padding-top:.7rem;
    font-size:.76rem; font-weight:700;
    color:hsl(var(--base)); text-decoration:none;
    display:flex; align-items:center; gap:4px;
    transition: gap .2s;
}
.st-link:hover { gap:8px; }
.st-link i { transition:transform .2s; }
.st-link:hover i { transform:translateX(3px); }

/* ── ⑤ Transactions ── */
.bento__txns {
    grid-column: 1 / 4;
    grid-row: 2;
}
.bento__txns:hover { transform:none; }

/* ── ⑥ Donut ── */
.bento__donut {
    grid-column: 1 / 3;
    grid-row: 3;
}

/* ── ⑦ Actions ── */
.bento__actions {
    grid-column: 3 / 5;
    grid-row: 3;
}

/* ════════════════════════════════════════════
   CARD HEADER
════════════════════════════════════════════ */
.c-hdr {
    display:flex; align-items:center; justify-content:space-between;
    padding:1.1rem 1.5rem;
    border-bottom:1px solid hsl(var(--border-color)/.5);
}
.c-hdr__l  { display:flex; align-items:center; gap:.55rem; }
.c-hdr__dot {
    width:8px; height:8px; border-radius:50%;
    background:linear-gradient(135deg,hsl(var(--base)),hsl(var(--base-two)));
    flex-shrink:0;
}
.c-hdr__title {
    font-size:.93rem; font-weight:700;
    color:hsl(var(--heading-color));
    font-family:'ClashDisplay-Variable',sans-serif;
}
.c-hdr__link {
    font-size:.76rem; font-weight:700; color:hsl(var(--base));
    text-decoration:none; display:flex; align-items:center; gap:4px;
    transition:gap .2s;
}
.c-hdr__link:hover { gap:8px; }

/* ════════════════════════════════════════════
   TRANSACTION FEED
════════════════════════════════════════════ */
.txn-feed { padding:.25rem 0; }

.txn-row {
    display:flex; align-items:center; gap:1rem;
    padding:.82rem 1.5rem;
    border-bottom:1px solid hsl(var(--border-color)/.35);
    transition:background .18s;
    animation: txnIn .4s ease both;
}
.txn-row:last-child { border-bottom:none; }
.txn-row:hover { background:hsl(var(--section-bg)); }

@@keyframes txnIn {
    from{opacity:0;transform:translateX(-8px);}
    to  {opacity:1;transform:translateX(0);}
}

.txn-ico {
    width:2.6rem; height:2.6rem; border-radius:.9rem;
    display:flex; align-items:center; justify-content:center;
    font-size:1.25rem; flex-shrink:0;
}
.txn-info { flex:1; min-width:0; }
.txn-name {
    font-size:.87rem; font-weight:600;
    color:hsl(var(--heading-color)); margin-bottom:2px;
}
.txn-meta {
    font-size:.73rem; color:hsl(var(--text-color)/.5);
    display:flex; align-items:center; gap:3px; flex-wrap:wrap;
}
.txn-meta i { font-size:.8rem; }
.txn-amt {
    font-size:.92rem; font-weight:800;
    color:hsl(var(--base)); white-space:nowrap;
    font-family:'ClashDisplay-Variable',sans-serif;
}
.txn-ok {
    width:1.7rem; height:1.7rem; border-radius:50%;
    background:hsl(var(--base)/.1); color:hsl(var(--base));
    display:flex; align-items:center; justify-content:center;
    font-size:.95rem; flex-shrink:0;
}

/* ════════════════════════════════════════════
   DONUT
════════════════════════════════════════════ */
.donut-wrap {
    display:flex; justify-content:center;
    padding:1.2rem 1.5rem .75rem;
}
.donut-svg {
    width:130px; height:130px;
    filter:drop-shadow(0 4px 12px hsl(var(--base)/.15));
}
.d-arc { animation: arcFade .7s ease both; }
.d-arc--b { animation-delay:.12s; }
@@keyframes arcFade { from{opacity:0;} to{opacity:1;} }

.donut-legs {
    display:flex; flex-direction:column; gap:.6rem;
    padding:0 1.5rem 1.5rem;
}
.d-leg {
    display:flex; align-items:center; gap:.5rem;
    font-size:.84rem; color:hsl(var(--text-color));
}
.d-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.d-leg span { flex:1; }
.d-leg strong {
    font-size:.97rem; font-weight:800;
    color:hsl(var(--heading-color));
    font-family:'ClashDisplay-Variable',sans-serif;
}

/* ════════════════════════════════════════════
   QUICK ACTIONS
════════════════════════════════════════════ */
.qa-grid {
    display:grid; grid-template-columns:1fr 1fr;
    gap:.7rem; padding:1rem 1.5rem 1.5rem;
}
.qa-tile {
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    gap:.4rem; padding:1.05rem .5rem;
    border-radius:1.1rem;
    border:1.5px solid hsl(var(--border-color));
    text-decoration:none;
    color:hsl(var(--text-color));
    font-size:.76rem; font-weight:600;
    background:hsl(var(--section-bg));
    transition:all .22s;
}
.qa-tile i { font-size:1.55rem; color:hsl(var(--base)); transition:transform .22s,color .22s; }
.qa-tile:hover {
    border-color:hsl(var(--base));
    background:hsl(var(--base)/.06);
    color:hsl(var(--heading-color));
    transform:translateY(-3px);
}
.qa-tile:hover i { transform:scale(1.15); color:hsl(var(--base-two)); }

.qa-glow {
    background:linear-gradient(135deg,hsl(var(--base)),hsl(var(--base-two)));
    border-color:transparent; color:#fff;
    box-shadow:0 6px 18px hsl(var(--base)/.28);
}
.qa-glow i { color:#fff; }
.qa-glow:hover {
    background:linear-gradient(135deg,hsl(var(--base-two)),hsl(var(--base)));
    color:#fff; border-color:transparent;
    box-shadow:0 10px 26px hsl(var(--base)/.38);
}
.qa-glow:hover i { color:#fff; transform:scale(1.1); }

/* ════════════════════════════════════════════
   RESPONSIVE
════════════════════════════════════════════ */
@@media (max-width:1200px) {
    .bento { grid-template-columns:1fr 1fr; }
    .bento__hero   { grid-column:1/-1; grid-row:1; }
    .bento__stat:nth-of-type(2) { grid-column:1; grid-row:2; }
    .bento__stat:nth-of-type(3) { grid-column:2; grid-row:2; }
    .bento__stat:nth-of-type(4) { grid-column:2; grid-row:3; }
    .bento__txns   { grid-column:1/-1; grid-row:4; }
    .bento__donut  { grid-column:1;    grid-row:3; }
    .bento__actions{ grid-column:1/-1; grid-row:5; }
}
@@media (max-width:600px) {
    .bento { grid-template-columns:1fr; }
    .bento__hero,.bento__stat:nth-of-type(2),.bento__stat:nth-of-type(3),
    .bento__stat:nth-of-type(4),.bento__txns,.bento__donut,.bento__actions {
        grid-column:1; grid-row:auto;
    }
    .hero-amount { font-size:2rem; }
}
</style>
