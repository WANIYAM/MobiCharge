@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

@{
    int topUp   = ViewBag.TotalTopUpPlans   ?? 0;
    int special = ViewBag.TotalSpecialPlans ?? 0;
    int total   = topUp + special;

    double circ       = 2 * Math.PI * 46;          // r=46
    double topUpArc   = total > 0 ? topUp   * circ / total : circ * 0.5;
    double specialArc = total > 0 ? special * circ / total : circ * 0.5;
}

<!-- ══════════════════ BENTO DASHBOARD ══════════════════ -->
<div class="bento">

    <!-- ① HERO REVENUE (spans 2 cols) -->
    <div class="bento__cell bento__hero">
        <div class="hero-orb hero-orb--a"></div>
        <div class="hero-orb hero-orb--b"></div>
        <div class="hero-orb hero-orb--c"></div>
        <div class="hero-body">
            <div class="hero-label">
                <span class="hero-pulse"></span> Total Revenue
            </div>
            <div class="hero-amount">Rs. @ViewBag.TotalRevenue</div>
            <div class="hero-sub">All-time platform earnings</div>
        </div>
        <div class="hero-icon-wrap">
            <i class="las la-chart-line"></i>
        </div>
    </div>

    <!-- ② USERS -->
    <div class="bento__cell bento__stat" style="--c:var(--base);">
        <div class="st-row">
            <div class="st-icon"><i class="las la-users"></i></div>
            <span class="st-badge st-badge--base">Active</span>
        </div>
        <div class="st-num">@ViewBag.TotalUsers</div>
        <div class="st-lbl">Registered Users</div>
        <a href="/Admin/Users" class="st-link">Manage users <i class="las la-long-arrow-alt-right"></i></a>
    </div>

    <!-- ③ TRANSACTIONS -->
    <div class="bento__cell bento__stat" style="--c:var(--base-two);">
        <div class="st-row">
            <div class="st-icon" style="background:hsl(var(--base-two)/.12);color:hsl(var(--base-two));">
                <i class="las la-exchange-alt"></i>
            </div>
            <span class="st-badge" style="background:hsl(var(--base-two)/.12);color:hsl(var(--base-two));">Total</span>
        </div>
        <div class="st-num">@ViewBag.TotalTransactions</div>
        <div class="st-lbl">Transactions</div>
        <a href="/Admin/Transactions" class="st-link" style="color:hsl(var(--base-two));">
            View all <i class="las la-long-arrow-alt-right"></i>
        </a>
    </div>

    <!-- ④ FEEDBACKS -->
    <div class="bento__cell bento__stat" style="--c:38 95% 48%;">
        <div class="st-row">
            <div class="st-icon" style="background:hsl(38 95% 48%/.12);color:hsl(38 95% 38%);">
                <i class="las la-comments"></i>
            </div>
        </div>
        <div class="st-num">@ViewBag.TotalFeedbacks</div>
        <div class="st-lbl">User Feedbacks</div>
        <a href="/Admin/Feedbacks" class="st-link" style="color:hsl(38 95% 38%);">
            View all <i class="las la-long-arrow-alt-right"></i>
        </a>
    </div>

    <!-- ⑤ RECENT TRANSACTIONS (wide) -->
    <div class="bento__cell bento__txns">
        <div class="c-hdr">
            <div class="c-hdr__l">
                <span class="c-hdr__dot"></span>
                <span class="c-hdr__title">Recent Transactions</span>
            </div>
            <a href="/Admin/Transactions" class="c-hdr__link">
                View all <i class="las la-arrow-right"></i>
            </a>
        </div>
        <div class="txn-feed">
            @if (ViewBag.RecentTransactions == null || ((IEnumerable<dynamic>)ViewBag.RecentTransactions).Count() == 0)
            {
                <div class="empty-state" style="padding:3rem;">
                    <i class="las la-inbox"></i><p>No transactions yet</p>
                </div>
            }
            else
            {
                int idx = 0;
                @foreach (var t in ViewBag.RecentTransactions)
                {
                    string icon  = t.PlanType == "topup"   ? "la-sim-card" :
                                   t.PlanType == "special" ? "la-star"     : "la-calendar";
                    string clr   = t.PlanType == "topup"   ? "var(--base)" :
                                   t.PlanType == "special" ? "var(--base-two)" : "38 95% 40%";
                    string label = t.PlanType == "topup"   ? "Top Up Recharge" :
                                   t.PlanType == "special" ? "Special Plan" : "Postpaid Bill";
                    idx++;

                    <div class="txn-row" style="animation-delay:@(idx * 0.06)s">
                        <div class="txn-ico" style="color:hsl(@clr);background:hsl(@clr/.1);">
                            <i class="las @icon"></i>
                        </div>
                        <div class="txn-info">
                            <div class="txn-name">@label</div>
                            <div class="txn-meta">
                                <i class="las la-phone-alt"></i> @t.MobileNumber
                                &nbsp;·&nbsp;
                                <i class="las la-clock"></i> @t.TxnDate.ToString("dd MMM · hh:mm tt")
                            </div>
                        </div>
                        <div class="txn-amt">+ Rs. @t.Amount</div>
                        <div class="txn-ok"><i class="las la-check-circle"></i></div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- ⑥ DONUT CHART -->
    <div class="bento__cell bento__donut">
        <div class="c-hdr">
            <div class="c-hdr__l">
                <span class="c-hdr__dot" style="background:hsl(var(--base-two));"></span>
                <span class="c-hdr__title">Plan Mix</span>
            </div>
        </div>
        <div class="donut-wrap">
            <svg viewBox="0 0 120 120" class="donut-svg">
                <circle cx="60" cy="60" r="46" fill="none"
                        stroke="hsl(var(--border-color))" stroke-width="11"/>
                <circle cx="60" cy="60" r="46" fill="none"
                        stroke="hsl(var(--base))" stroke-width="11"
                        stroke-linecap="round"
                        stroke-dasharray="@topUpArc.ToString("F1") @circ.ToString("F1")"
                        transform="rotate(-90 60 60)"
                        class="d-arc"/>
                <circle cx="60" cy="60" r="46" fill="none" style="font-family:'Outfit', sans-serif;"
                        stroke="hsl(var(--base-two))" stroke-width="11" 
                        stroke-linecap="round"
                        stroke-dasharray="@specialArc.ToString("F1") @circ.ToString("F1")"
                        stroke-dashoffset="-@topUpArc.ToString("F1")"
                        transform="rotate(-90 60 60)"
                        class="d-arc d-arc--b"/>
                <text x="60" y="56" text-anchor="middle"
                      font-size="17" font-weight="800"
                      fill="hsl(var(--heading-color))"
                      font-family=""Outfit", sans-serif">@total</text>
                <text x="60" y="70" text-anchor="middle"
                      font-size="7.5" fill="hsl(var(--text-color))"
                      font-family="sans-serif">Plans</text>
            </svg>
        </div>
        <div class="donut-legs">
            <div class="d-leg">
                <span class="d-dot" style="background:hsl(var(--base));"></span>
                <span>Top Up</span>
                <strong>@topUp</strong>
            </div>
            <div class="d-leg">
                <span class="d-dot" style="background:hsl(var(--base-two));"></span>
                <span>Special</span>
                <strong>@special</strong>
            </div>
        </div>
    </div>

    <!-- ⑦ QUICK ACTIONS -->
    <div class="bento__cell bento__actions">
        <div class="c-hdr">
            <div class="c-hdr__l">
                <span class="c-hdr__dot" style="background:hsl(38 95% 55%);"></span>
                <span class="c-hdr__title">Quick Actions</span>
            </div>
        </div>
        <div class="qa-grid">
            <a href="/Admin/CreateUser"     class="qa-tile">
                <i class="las la-user-plus"></i><span>Add User</span>
            </a>
            <a href="/Admin/AddTopUpPlan"   class="qa-tile">
                <i class="las la-mobile"></i><span>Top Up Plan</span>
            </a>
            <a href="/Admin/AddSpecialPlan" class="qa-tile">
                <i class="las la-star"></i><span>Special Plan</span>
            </a>
            <a href="/" target="_blank"     class="qa-tile qa-glow">
                <i class="las la-external-link-alt"></i><span>View Site</span>
            </a>
        </div>
    </div>

</div>

<style>
/* ════════════════════════════════════════════
   BENTO GRID — MODERN GLASSMORPHIC DESIGN
════════════════════════════════════════════ */
@@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

* {
    font-family: "Plus Jakarta Sans", sans-serif;
}

.bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    padding: 0.5rem;
    animation: fadeScale 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
}

@@keyframes fadeScale {
    from { 
        opacity: 0; 
        transform: scale(0.98) translateY(10px);
    }
    to { 
        opacity: 1; 
        transform: scale(1) translateY(0);
    }
}

/* base cell — modern glass effect */
.bento__cell {
    background: hsl(var(--white) / 0.8);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 2rem;
    border: 1px solid hsl(var(--border-color) / 0.3);
    box-shadow: 
        0 4px 24px -8px hsl(0 0% 0% / 0.1),
        inset 0 0 0 1px hsl(var(--white) / 0.5);
    overflow: hidden;
    position: relative;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.bento__cell:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: 
        0 20px 40px -12px hsl(var(--base) / 0.25),
        inset 0 0 0 1px hsl(var(--white) / 0.8);
    border-color: hsl(var(--base) / 0.2);
}

/* ── ① Hero — gradient with floating elements ── */
.bento__hero {
    grid-column: 1 / 3;
    grid-row: 1;
    background: linear-gradient(145deg,
        hsl(var(--base) / 0.95) 0%,
        hsl(var(--base-two) / 0.95) 100%);
    border-color: transparent;
    box-shadow: 
        0 25px 40px -15px hsl(var(--base) / 0.5),
        inset 0 1px 2px hsl(0 0% 100% / 0.3);
    padding: 2rem 2.2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    min-height: 170px;
    backdrop-filter: none;
}

/* animated floating orbs */
.hero-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(40px);
    opacity: 0.6;
    animation: float 8s infinite ease-in-out;
}

.hero-orb--a { 
    width: 250px; 
    height: 250px; 
    background: hsl(0 0% 100% / 0.15); 
    top: -80px; 
    right: 80px; 
    animation-delay: 0s;
}
.hero-orb--b { 
    width: 150px; 
    height: 150px; 
    background: hsl(0 0% 0% / 0.1); 
    bottom: -50px; 
    left: 20px; 
    animation-delay: 2s;
}
.hero-orb--c { 
    width: 100px; 
    height: 100px; 
    background: hsl(0 0% 100% / 0.2); 
    top: 20px; 
    right: 30%; 
    animation-delay: 4s;
}

@@keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.1); }
}

.hero-body { 
    position: relative; 
    z-index: 2; 
}

.hero-label {
    display: flex; 
    align-items: center; 
    gap: 0.6rem;
    font-size: 0.8rem; 
    font-weight: 500;
    color: hsl(0 0% 100% / 0.9);
    text-transform: uppercase; 
    letter-spacing: 0.1em;
    margin-bottom: 0.8rem;
    backdrop-filter: blur(4px);
    background: hsl(0 0% 100% / 0.1);
    padding: 0.4rem 1rem 0.4rem 0.8rem;
    border-radius: 40px;
    width: fit-content;
}

.hero-pulse {
    width: 8px; 
    height: 8px; 
    border-radius: 50%; 
    background: #fff; 
    flex-shrink: 0;
    box-shadow: 0 0 10px #fff;
    animation: hbeat 2s infinite;
}

@@keyframes hbeat {
    0%, 100% { 
        opacity: 1; 
        transform: scale(1);
        box-shadow: 0 0 10px #fff;
    }
    50% { 
        opacity: 0.5; 
        transform: scale(0.8);
        box-shadow: 0 0 20px #fff;
    }
}

.hero-amount {
    font-size: 3.2rem; 
    font-weight: 700; 
    color: #fff;
    line-height: 1; 
    letter-spacing: -0.02em;
    font-family: "Plus Jakarta Sans", sans-serif;
    margin-bottom: 0.3rem;
    text-shadow: 0 2px 10px hsl(0 0% 0% / 0.2);
}

.hero-sub { 
    font-size: 0.85rem; 
    color: hsl(0 0% 100% / 0.7);
    font-weight: 400;
    letter-spacing: 0.02em;
}

.hero-icon-wrap {
    position: relative; 
    z-index: 2; 
    align-self: flex-start;
    width: 4rem; 
    height: 4rem; 
    border-radius: 1.2rem;
    background: hsl(0 0% 100% / 0.2); 
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    display: flex; 
    align-items: center; 
    justify-content: center;
    font-size: 2rem; 
    color: #fff;
    border: 1px solid hsl(0 0% 100% / 0.3);
    box-shadow: 0 10px 20px -5px hsl(0 0% 0% / 0.2);
}

/* ── ② ③ ④ Stats — modern cards ── */
.bento__stat {
    padding: 1.8rem 1.8rem 1.5rem;
    display: flex; 
    flex-direction: column;
    background: linear-gradient(145deg, 
        hsl(var(--white) / 0.9), 
        hsl(var(--white) / 0.7));
}

.bento__stat:nth-of-type(2) { grid-column: 3; grid-row: 1; }
.bento__stat:nth-of-type(3) { grid-column: 4; grid-row: 1; }
.bento__stat:nth-of-type(4) { grid-column: 4; grid-row: 2; }

/* gradient accent line */
.bento__stat::after {
    content: '';
    position: absolute;
    top: 0;
    left: 1.8rem;
    right: 1.8rem;
    height: 3px;
    background: linear-gradient(90deg, 
        hsl(var(--c, var(--base))), 
        hsl(var(--base-two)));
    border-radius: 3px;
    opacity: 0.5;
    transition: opacity 0.3s;
}

.bento__stat:hover::after {
    opacity: 1;
}

.st-row { 
    display: flex; 
    align-items: center; 
    justify-content: space-between; 
    margin-bottom: 0.8rem; 
}

.st-icon {
    width: 3rem; 
    height: 3rem; 
    border-radius: 1rem;
    background: hsl(var(--base) / 0.1); 
    color: hsl(var(--base));
    display: flex; 
    align-items: center; 
    justify-content: center;
    font-size: 1.5rem;
    transition: all 0.3s;
    border: 1px solid hsl(var(--base) / 0.1);
}

.bento__stat:hover .st-icon {
    transform: scale(1.05) rotate(5deg);
    background: hsl(var(--base) / 0.15);
}

.st-badge {
    font-size: 0.7rem; 
    font-weight: 600; 
    padding: 0.3rem 0.9rem;
    border-radius: 30px; 
    letter-spacing: 0.02em;
    background: hsl(var(--base) / 0.1); 
    color: hsl(var(--base));
    border: 1px solid hsl(var(--base) / 0.1);
}

.st-num {
    font-size: 2.4rem; 
    font-weight: 700;
    color: hsl(var(--heading-color));
    line-height: 1.1; 
    letter-spacing: -0.02em;
    font-family: "Plus Jakarta Sans", sans-serif;
    margin: 0.5rem 0 0.2rem;
}

.st-lbl { 
    font-size: 0.85rem; 
    color: hsl(var(--text-color) / 0.7); 
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.02em;
}

.st-link {
    margin-top: 1rem; 
    padding-top: 0.8rem;
    font-size: 0.8rem; 
    font-weight: 600;
    color: hsl(var(--base)); 
    text-decoration: none;
    display: flex; 
    align-items: center; 
    gap: 6px;
    border-top: 1px dashed hsl(var(--border-color) / 0.5);
    transition: all 0.2s;
}

.st-link:hover { 
    gap: 12px; 
    color: hsl(var(--base-two));
}

/* ── ⑤ Transactions ── */
.bento__txns {
    grid-column: 1 / 4;
    grid-row: 2;
}

/* ── ⑥ Donut ── */
.bento__donut {
    grid-column: 1 / 3;
    grid-row: 3;
}

/* ── ⑦ Actions ── */
.bento__actions {
    grid-column: 3 / 5;
    grid-row: 3;
}

/* ════════════════════════════════════════════
   CARD HEADER — refined
════════════════════════════════════════════ */
.c-hdr {
    display: flex; 
    align-items: center; 
    justify-content: space-between;
    padding: 1.2rem 1.8rem;
    border-bottom: 1px solid hsl(var(--border-color) / 0.2);
    background: hsl(var(--white) / 0.3);
}

.c-hdr__l { 
    display: flex; 
    align-items: center; 
    gap: 0.7rem; 
}

.c-hdr__dot {
    width: 10px; 
    height: 10px; 
    border-radius: 50%;
    background: linear-gradient(135deg, 
        hsl(var(--base)), 
        hsl(var(--base-two)));
    box-shadow: 0 0 0 2px hsl(var(--base) / 0.2);
}

.c-hdr__title {
    font-size: 1rem; 
    font-weight: 700;
    color: hsl(var(--heading-color));
    font-family: "Plus Jakarta Sans", sans-serif;
    letter-spacing: -0.01em;
}

.c-hdr__link {
    font-size: 0.8rem; 
    font-weight: 600; 
    color: hsl(var(--base));
    text-decoration: none; 
    display: flex; 
    align-items: center; 
    gap: 6px;
    padding: 0.4rem 1rem;
    background: hsl(var(--base) / 0.1);
    border-radius: 40px;
    transition: all 0.2s;
}

.c-hdr__link:hover { 
    gap: 10px; 
    background: hsl(var(--base) / 0.15);
    transform: translateX(2px);
}

/* ════════════════════════════════════════════
   TRANSACTION FEED — smooth animations
════════════════════════════════════════════ */
.txn-feed { 
    padding: 0.2rem 0; 
    max-height: 320px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: hsl(var(--base) / 0.3) transparent;
}

.txn-feed::-webkit-scrollbar {
    width: 4px;
}

.txn-feed::-webkit-scrollbar-track {
    background: transparent;
}

.txn-feed::-webkit-scrollbar-thumb {
    background: hsl(var(--base) / 0.3);
    border-radius: 20px;
}

.txn-row {
    display: flex; 
    align-items: center; 
    gap: 1.2rem;
    padding: 1rem 1.8rem;
    border-bottom: 1px solid hsl(var(--border-color) / 0.2);
    transition: all 0.3s;
    animation: slideIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    position: relative;
    overflow: hidden;
}

.txn-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(to bottom, 
        hsl(var(--base)), 
        hsl(var(--base-two)));
    opacity: 0;
    transition: opacity 0.3s;
}

.txn-row:hover::before {
    opacity: 1;
}

.txn-row:last-child { border-bottom: none; }
.txn-row:hover { 
    background: hsl(var(--section-bg) / 0.8);
    transform: translateX(4px);
}

@@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateX(-20px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

.txn-ico {
    width: 3rem; 
    height: 3rem; 
    border-radius: 1rem;
    display: flex; 
    align-items: center; 
    justify-content: center;
    font-size: 1.4rem; 
    flex-shrink: 0;
    transition: all 0.3s;
    border: 1px solid hsl(var(--base) / 0.1);
}

.txn-row:hover .txn-ico {
    transform: scale(1.1) rotate(5deg);
    background: hsl(var(--base) / 0.15) !important;
}

.txn-info { flex: 1; min-width: 0; }

.txn-name {
    font-size: 0.95rem; 
    font-weight: 600;
    color: hsl(var(--heading-color)); 
    margin-bottom: 0.2rem;
    font-family: "Plus Jakarta Sans", sans-serif;
}

.txn-meta {
    font-size: 0.75rem; 
    color: hsl(var(--text-color) / 0.6);
    display: flex; 
    align-items: center; 
    gap: 4px; 
    flex-wrap: wrap;
}

.txn-meta i { 
    font-size: 0.85rem; 
    opacity: 0.7;
}

.txn-amt {
    font-size: 1rem; 
    font-weight: 700;
    color: hsl(var(--base)); 
    white-space: nowrap;
    font-family: "Plus Jakarta Sans", sans-serif;
    background: hsl(var(--base) / 0.1);
    padding: 0.3rem 0.8rem;
    border-radius: 40px;
    border: 1px solid hsl(var(--base) / 0.1);
}

.txn-ok {
    width: 2rem; 
    height: 2rem; 
    border-radius: 50%;
    background: hsl(var(--base) / 0.1); 
    color: hsl(var(--base));
    display: flex; 
    align-items: center; 
    justify-content: center;
    font-size: 1.1rem; 
    flex-shrink: 0;
    transition: all 0.3s;
}

.txn-row:hover .txn-ok {
    transform: scale(1.1);
    background: hsl(var(--base) / 0.2);
}

/* ════════════════════════════════════════════
   DONUT — enhanced
════════════════════════════════════════════ */
.donut-wrap {
    display: flex; 
    justify-content: center;
    padding: 1.5rem 1.8rem 1rem;
    position: relative;
}

.donut-wrap::before {
    content: '';
    position: absolute;
    width: 150px;
    height: 150px;
    background: radial-gradient(circle at 30% 30%, 
        hsl(var(--base) / 0.1), 
        transparent 70%);
    border-radius: 50%;
    filter: blur(20px);
}

.donut-svg {
    width: 140px; 
    height: 140px;
    filter: drop-shadow(0 8px 16px hsl(var(--base) / 0.2));
    position: relative;
    z-index: 2;
}

.d-arc { 
    animation: arcDraw 1s cubic-bezier(0.16, 1, 0.3, 1) both; 
    transition: stroke-dasharray 0.5s;
}

@@keyframes arcDraw {
    from { 
        opacity: 0;
        stroke-dasharray: 0 289;
    }
}

.donut-legs {
    display: flex; 
    flex-direction: column; 
    gap: 0.8rem;
